      "routes": [
        {
          "name": "dashboard",
          "pattern": "",
          "target": [
            "Dashboard"
          ]
        },
        {
          "name": "departmentDetail",
          "pattern": "department/{orgId}",
          "target": [
            "DepartmentDetail"
          ]
        },
        {
