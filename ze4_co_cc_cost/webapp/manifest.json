            "DocumentDetail"
          ]
        },
        {
          "name": "allocationAnalysis",
          "pattern": "allocation",
          "target": [
            "AllocationAnalysis"
          ]
        },
        {
          "name": "allocationDetail",
          "pattern": "allocation/detail/{selection}",
          "target": [
            "AllocationAnalysis"
          ]
        },
        {
          "name": "allocationMap",
          "pattern": "allocation-map/{gjahr}/{period}",
