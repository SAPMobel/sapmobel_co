            "AllocationFlowLanding"
          ]
        },
        {
          "name": "allocationFlowDetail",
          "pattern": "allocation-flow/detail/{context}",
          "target": [
            "AllocationFlowDetail"
          ]
        }
      ],
      "targets": {
        "Dashboard": {
          "id": "Dashboard",
          "name": "Dashboard"
        },
        "DepartmentDetail": {
          "id": "DepartmentDetail",
          "name": "DepartmentDetail"
        },
        "DocumentDetail": {
          "id": "DocumentDetail",
          "name": "DocumentDetail"
        },
        "AllocationAnalysis": {
