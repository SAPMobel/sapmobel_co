<mvc:View
    controllerName="ZE4_CC_COST.controller.AllocationFlowDetail"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table">
    <Page
        class="ze4DynamicPage ze4AllocationFlowPage ze4AllocationFlowDetailPage sapUiSizeCompact"
        showHeader="false"
        enableScrolling="false"
        busy="{flow2>/busy}"
        busyIndicatorDelay="0">
        <content>
            <VBox class="ze4PageContent ze4AllocationFlowContent ze4AllocationFlowDetailContent">
                <HBox class="ze4PageTitleBar" alignItems="Center" wrap="Wrap">
                    <Title text="{flow2>/pageTitle}" level="H1" titleStyle="H1" class="ze4PageHeroTitle" />
                    <ToolbarSpacer />
                    <HBox class="ze4PageActions" alignItems="Center">
                        <Button text="전체 흐름" icon="sap-icon://process" type="Transparent" press=".onGoAllocationFlowOverview" />
                        <Button text="대시보드" icon="sap-icon://home" type="Transparent" press=".onGoDashboard" />
                        <Button text="조직도 탐색" icon="sap-icon://org-chart" type="Transparent" press=".onGoOrgExplorer" />
                    </HBox>
                </HBox>

                <FlexBox class="ze4ContextChipBar" wrap="Wrap" items="{flow2>/contextChips}">
                    <ObjectStatus text="{flow2>label}: {flow2>text}" state="Information" />
                </FlexBox>

                <VBox class="ze4AllocationFilterBar">
                    <HBox class="ze4FilterHeader" alignItems="Center">
                        <Title text="조회 조건" level="H3" />
                        <ToolbarSpacer />
                        <Button text="{flow2>/filterToggleText}" type="Transparent" press=".onToggleFilter" />
                    </HBox>
                    <FlexBox class="ze4FilterFields" visible="{flow2>/filterVisible}" wrap="Wrap" alignItems="End">
                        <VBox class="ze4FilterField">
                            <Label text="회사코드" required="true" />
                            <Input value="0001 (EverNiture CO., LTD.)" editable="false" enabled="false" width="13rem" />
                        </VBox>
                        <VBox class="ze4FilterField">
                            <Label text="회계연도" required="true" />
                            <Input
                                value="{flow2>/filters/gjahr}"
                                valueState="{flow2>/filterStates/gjahrState}"
                                valueStateText="{flow2>/filterStates/gjahrStateText}"
                                maxLength="4"
                                width="8rem" />
                        </VBox>
                        <VBox class="ze4FilterField">
                            <Label text="기간" required="true" />
                            <Select
                                selectedKey="{flow2>/filters/period}"
                                valueState="{flow2>/filterStates/periodState}"
                                valueStateText="{flow2>/filterStates/periodStateText}"
                                items="{flow2>/periodOptions}"
                                width="8rem">
                                <core:Item key="{flow2>key}" text="{flow2>text}" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField ze4FilterFieldWide">
                            <Label text="송신 코스트센터" />
                            <Select selectedKey="{flow2>/filters/senderKostl}" items="{flow2>/senderCostCenterOptions}" width="13rem">
                                <core:Item key="{flow2>key}" text="{flow2>text}" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField ze4FilterFieldWide">
                            <Label text="수신 코스트센터" />
                            <Select selectedKey="{flow2>/filters/receiverKostl}" items="{flow2>/receiverCostCenterOptions}" width="13rem">
                                <core:Item key="{flow2>key}" text="{flow2>text}" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField ze4FilterFieldWide">
                            <Label text="세그먼트" />
                            <Select selectedKey="{flow2>/filters/segmNo}" items="{flow2>/segmentOptions}" width="12rem">
                                <core:Item key="{flow2>key}" text="{flow2>text}" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField ze4FilterFieldWide">
                            <Label text="배부기준/SKF" />
                            <Select selectedKey="{flow2>/filters/skfId}" items="{flow2>/skfOptions}" width="12rem">
                                <core:Item key="{flow2>key}" text="{flow2>text}" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField">
                            <Label text="전표번호" />
                            <Input value="{flow2>/filters/belnr}" placeholder="전표번호 입력" width="11rem" />
                        </VBox>
                        <Button class="ze4SearchButton" text="조회" icon="sap-icon://search" type="Emphasized" press=".onSearch" />
                        <Button text="초기화" type="Transparent" press=".onResetFilters" />
                    </FlexBox>
                    <MessageStrip
                        class="ze4MessageStrip"
                        visible="{flow2>/warningVisible}"
                        text="{flow2>/warningText}"
                        type="Warning"
                        showIcon="true" />
                </VBox>

                <FlexBox class="ze4AllocationKpiGrid" wrap="Wrap" items="{flow2>/kpis}">
                    <VBox class="ze4KpiCard ze4AllocationKpiCard">
                        <HBox class="ze4KpiCardBody" alignItems="Center">
                            <core:Icon src="{flow2>icon}" class="ze4KpiIcon" color="{flow2>iconColor}" backgroundColor="{flow2>iconBackground}" />
                            <VBox class="ze4KpiText">
                                <Text class="ze4KpiTitle" text="{flow2>title}" />
                                <ObjectStatus class="ze4KpiValueStatus" text="{flow2>valueText}" state="{flow2>valueState}" tooltip="{flow2>valueText}" />
                                <VBox class="ze4KpiDetailList" items="{flow2>detailLines}">
                                    <HBox class="ze4KpiDetailLine" alignItems="Center">
                                        <Text class="ze4KpiDetailLabel" text="{flow2>label}" tooltip="{flow2>label}" />
                                        <Text class="ze4KpiDetailValue" text="{flow2>value}" tooltip="{flow2>value}" />
                                    </HBox>
                                </VBox>
                            </VBox>
                        </HBox>
                        <ObjectStatus class="ze4KpiSub" text="{flow2>subText}" state="{flow2>state}" visible="{= !!${flow2>subText} }" />
                    </VBox>
                </FlexBox>

                <HBox class="ze4AllocationDetailMainGrid">
                    <layoutData>
                        <FlexItemData growFactor="1" shrinkFactor="1" baseSize="0" />
                    </layoutData>
                    <VBox class="ze4Card ze4TableCard ze4AllocationDetailMainTable">
                        <HBox class="ze4CardHeader" alignItems="Center">
                            <Title text="배부 전표 상세" level="H3" />
                            <ToolbarSpacer />
                            <Text class="ze4CardUnit" text="단위: KRW" />
                        </HBox>
                        <t:Table
                            id="allocationFlowDetailTable"
                            rows="{flow2>/detailRows}"
                            selectionMode="Single"
                            selectionBehavior="Row"
                            rowSelectionChange=".onDetailRowSelection"
                            visibleRowCount="{flow2>/detailVisibleRowCount}"
                            width="100%"
                            fixedColumnCount="2"
                            enableColumnReordering="true"
                            noData="조회 조건에 해당하는 배부 데이터가 없습니다."
                            class="ze4GridTable ze4Table ze4AllocationDetailTable">
                            <t:columns>
                                <t:Column width="10rem"><Label text="송신 코스트센터" /><t:template><Text text="{flow2>senderText}" wrapping="false" tooltip="{flow2>senderText}" class="ze4NoWrapText" /></t:template></t:Column>
                                <t:Column width="10.5rem"><Label text="수신 코스트센터" /><t:template><Text text="{flow2>receiverText}" wrapping="false" tooltip="{flow2>receiverText}" class="ze4NoWrapText" /></t:template></t:Column>
                                <t:Column width="15rem"><Label text="배부사이클" /><t:template><Text text="{flow2>cycleText}" wrapping="false" tooltip="{flow2>cycleText}" class="ze4NoWrapText" /></t:template></t:Column>
                                <t:Column width="16rem"><Label text="세그먼트" /><t:template><Text text="{flow2>segmentText}" wrapping="false" tooltip="{flow2>segmentText}" class="ze4NoWrapText" /></t:template></t:Column>
                                <t:Column width="7.5rem"><Label text="배부기준" /><t:template><Text text="{flow2>skfText}" wrapping="false" tooltip="{flow2>skfText}" class="ze4NoWrapText" /></t:template></t:Column>
                                <t:Column width="9rem" hAlign="End"><Label text="배부기준값" /><t:template><Text text="{flow2>basisValueText}" textAlign="End" wrapping="false" tooltip="{flow2>basisValueText}" class="ze4AmountText" /></t:template></t:Column>
                                <t:Column width="5rem" hAlign="End"><Label text="비율" /><t:template><Text text="{flow2>basisRatioText}" textAlign="End" wrapping="false" tooltip="{flow2>basisRatioText}" class="ze4RateText" /></t:template></t:Column>
                                <t:Column width="9rem" hAlign="End"><Label text="배부금액" /><t:template><Text text="{path: 'flow2>amount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText" /></t:template></t:Column>
                                <t:Column width="8.5rem"><Label text="전표번호" /><t:template><Text text="{flow2>belnr}" wrapping="false" tooltip="{flow2>belnr}" /></t:template></t:Column>
                                <t:Column width="5.5rem"><Label text="라인" /><t:template><Text text="{flow2>docln}" wrapping="false" tooltip="{flow2>docln}" /></t:template></t:Column>
                                <t:Column width="7.5rem"><Label text="전기일자" /><t:template><Text text="{flow2>budatText}" wrapping="false" tooltip="{flow2>budatText}" /></t:template></t:Column>
                                <t:Column width="8.5rem"><Label text="계정명" /><t:template><Text text="{flow2>saknrText}" wrapping="false" tooltip="{flow2>saknrText}" class="ze4NoWrapText" /></t:template></t:Column>
                                <t:Column width="4rem"><Label text="통화" /><t:template><Text text="{flow2>waers}" wrapping="false" tooltip="{flow2>waers}" /></t:template></t:Column>
                            </t:columns>
                        </t:Table>
                    </VBox>

                    <VBox class="ze4AllocationRightStack">
                        <VBox class="ze4Card ze4AllocationRulePanel">
                            <HBox class="ze4CardHeader" alignItems="Center">
                                <Title text="선택 배부 규칙" level="H3" />
                                <ToolbarSpacer />
                                <ObjectStatus class="ze4RuleStatusBadge" text="{flow2>/selectedDetail/ruleStatusText}" state="{flow2>/selectedDetail/ruleState}" />
                            </HBox>
                            <VBox class="ze4DetailList">
                                <Label text="배부사이클" class="ze4DetailLabel" /><Text text="{flow2>/selectedDetail/cycleText}" class="ze4DetailValue" wrapping="true" />
                                <Label text="세그먼트" class="ze4DetailLabel" /><Text text="{flow2>/selectedDetail/segmentText}" class="ze4DetailValue" wrapping="true" />
                                <Label text="배부기준" class="ze4DetailLabel" /><Text text="{flow2>/selectedDetail/skfText}" class="ze4DetailValue" wrapping="true" />
                                <Label text="SKF ID" class="ze4DetailLabel" /><Text text="{flow2>/selectedDetail/skfId}" class="ze4DetailValue" wrapping="true" />
                                <Label text="기준값" class="ze4DetailLabel" /><Text text="{flow2>/selectedDetail/basisValueText}" class="ze4DetailValue ze4MetricValue" wrapping="true" />
                                <Label text="수신 비율" class="ze4DetailLabel" /><Text text="{flow2>/selectedDetail/basisRatioText}" class="ze4DetailValue ze4MetricValue" wrapping="true" />
                            </VBox>
                        </VBox>

                        <VBox class="ze4Card ze4TableCard ze4AllocationSkfPanel">
                            <HBox class="ze4CardHeader" alignItems="Center">
                                <Title text="SKF 기준값 요약" level="H3" />
                                <ToolbarSpacer />
                                <Text class="ze4CardUnit" text="기준값" />
                            </HBox>
                            <t:Table
                                rows="{flow2>/skfSummaryRows}"
                                selectionMode="None"
                                visibleRowCount="6"
                                rowHeaderVisible="false"
                                width="100%"
                                noData="배부기준값을 찾을 수 없습니다."
                                class="ze4GridTable ze4Table ze4SkfSummaryTable">
                                <t:columns>
                                    <t:Column width="52%"><Label text="수신 코스트센터" /><t:template><Text text="{flow2>receiverText}" wrapping="false" tooltip="{flow2>receiverText}" class="ze4NoWrapText" /></t:template></t:Column>
                                    <t:Column width="28%" hAlign="End"><Label text="기준값" /><t:template><Text text="{path: 'flow2>basisValue', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText" /></t:template></t:Column>
                                    <t:Column width="20%" hAlign="End"><Label text="비율" /><t:template><Text text="{flow2>ratioText}" textAlign="End" wrapping="false" tooltip="{flow2>ratioText}" class="ze4RateText" /></t:template></t:Column>
                                </t:columns>
                            </t:Table>
                        </VBox>

                        <VBox class="ze4Card ze4AllocationDetailTabsCard">
                            <IconTabBar expandable="false" class="ze4IconTabBar">
                                <items>
                                    <IconTabFilter key="document" text="전표 상세">
                                        <VBox class="ze4TabFactGrid">
                                            <ObjectAttribute title="전표번호" text="{flow2>/selectedDetail/belnr}" />
                                            <ObjectAttribute title="전기일자" text="{flow2>/selectedDetail/budatText}" />
                                            <ObjectAttribute title="라인" text="{flow2>/selectedDetail/docln}" />
                                            <ObjectAttribute title="계정명" text="{flow2>/selectedDetail/saknrText}" />
                                            <ObjectAttribute title="통화" text="{flow2>/selectedDetail/waers}" />
                                            <ObjectAttribute title="전표 상태" text="{flow2>/selectedDetail/documentStatusText}" />
                                        </VBox>
                                    </IconTabFilter>
                                    <IconTabFilter key="rule" text="배부규칙">
                                        <VBox class="ze4TabFactGrid">
                                            <ObjectAttribute title="배부사이클" text="{flow2>/selectedDetail/cycleText}" />
                                            <ObjectAttribute title="세그먼트" text="{flow2>/selectedDetail/segmentText}" />
                                            <ObjectAttribute title="배부기준" text="{flow2>/selectedDetail/skfText}" />
                                            <ObjectAttribute title="기준값" text="{flow2>/selectedDetail/basisValueText}" />
                                            <ObjectAttribute title="비율" text="{flow2>/selectedDetail/basisRatioText}" />
                                        </VBox>
                                    </IconTabFilter>
                                    <IconTabFilter key="skf" text="SKF 기준값">
                                        <VBox class="ze4TabFactGrid">
                                            <ObjectAttribute title="SKF ID" text="{flow2>/selectedDetail/skfId}" />
                                            <ObjectAttribute title="기준값" text="{flow2>/selectedDetail/basisValueText}" />
                                            <ObjectAttribute title="수신 비율" text="{flow2>/selectedDetail/basisRatioText}" />
                                            <ObjectAttribute title="상태" text="{flow2>/selectedDetail/ruleStatusText}" />
                                        </VBox>
                                    </IconTabFilter>
                                </items>
                            </IconTabBar>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
