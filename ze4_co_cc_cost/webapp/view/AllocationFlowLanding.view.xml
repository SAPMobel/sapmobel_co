<mvc:View
    controllerName="ZE4_CC_COST.controller.AllocationFlowLanding"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table">
    <Page
        class="ze4DynamicPage ze4AllocationFlowPage sapUiSizeCompact"
        showHeader="false"
        enableScrolling="true"
        busy="{flow1>/busy}"
        busyIndicatorDelay="0">
        <content>
            <VBox class="ze4PageContent ze4AllocationFlowContent">
                <HBox class="ze4PageTitleBar" alignItems="Center" wrap="Wrap">
                    <VBox>
                        <Title text="{flow1>/pageTitle}" level="H1" titleStyle="H1" class="ze4PageHeroTitle" />
                        <Text text="{flow1>/subtitle}" class="ze4PageSubtitle" />
                    </VBox>
                    <ToolbarSpacer />
                    <HBox class="ze4PageActions" alignItems="Center">
                        <Button text="전체 흐름" icon="sap-icon://process" type="Transparent" press=".onGoAllocationFlowOverview" />
                        <Button text="대시보드" icon="sap-icon://home" type="Transparent" press=".onGoDashboard" />
                        <Button text="조직도 탐색" icon="sap-icon://org-chart" type="Transparent" press=".onGoOrgExplorer" />
                    </HBox>
                </HBox>

                <VBox class="ze4AllocationFilterBar">
                    <HBox class="ze4FilterHeader" alignItems="Center">
                        <Title text="조회 조건" level="H3" />
                        <ToolbarSpacer />
                        <Button text="{flow1>/filterToggleText}" type="Transparent" press=".onToggleFilter" />
                    </HBox>
                    <FlexBox class="ze4FilterFields" visible="{flow1>/filterVisible}" wrap="Wrap" alignItems="End">
                        <VBox class="ze4FilterField">
                            <Label text="회사코드" required="true" />
                            <Input value="0001 (EverNiture CO., LTD.)" editable="false" enabled="false" width="13rem" />
                        </VBox>
                        <VBox class="ze4FilterField">
                            <Label text="회계연도" required="true" />
                            <Input
                                value="{flow1>/filters/gjahr}"
                                valueState="{flow1>/filterStates/gjahrState}"
                                valueStateText="{flow1>/filterStates/gjahrStateText}"
                                maxLength="4"
                                width="8rem" />
                        </VBox>
                        <VBox class="ze4FilterField">
                            <Label text="기간" required="true" />
                            <Select
                                selectedKey="{flow1>/filters/period}"
                                valueState="{flow1>/filterStates/periodState}"
                                valueStateText="{flow1>/filterStates/periodStateText}"
                                items="{flow1>/periodOptions}"
                                width="8rem">
                                <core:Item key="{flow1>key}" text="{flow1>text}" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField ze4FilterFieldWide">
                            <Label text="선택 CCG" required="true" />
                            <Select
                                selectedKey="{flow1>/filters/selectedCcgId}"
                                valueState="{flow1>/filterStates/selectedCcgState}"
                                valueStateText="{flow1>/filterStates/selectedCcgStateText}"
                                items="{flow1>/selectedCcgOptions}"
                                width="15rem">
                                <core:Item key="{flow1>key}" text="{flow1>text}" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField ze4FilterFieldWide">
                            <Label text="송신 CCG" />
                            <Select selectedKey="{flow1>/filters/senderCcgId}" items="{flow1>/senderCcgOptions}" width="15rem">
                                <core:Item key="{flow1>key}" text="{flow1>text}" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField ze4FilterFieldWide">
                            <Label text="보기 기준" />
                            <Select selectedKey="{flow1>/filters/viewMode}" width="12rem">
                                <core:Item key="RECEIVER" text="수신처 기준" />
                                <core:Item key="SENDER" text="송신처 기준" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField ze4FilterFieldWide">
                            <Label text="배부사이클" />
                            <Select selectedKey="{flow1>/filters/cycle}" items="{flow1>/cycleOptions}" width="17rem">
                                <core:Item key="{flow1>key}" text="{flow1>text}" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField ze4FilterFieldWide">
                            <Label text="배부기준/SKF" />
                            <Select selectedKey="{flow1>/filters/skfId}" items="{flow1>/skfOptions}" width="14rem">
                                <core:Item key="{flow1>key}" text="{flow1>text}" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField">
                            <Label text="내부 재배부" />
                            <Switch state="{flow1>/filters/includeInternal}" />
                        </VBox>
                        <Button class="ze4SearchButton" text="조회" icon="sap-icon://search" type="Emphasized" press=".onSearch" />
                        <Button text="초기화" type="Transparent" press=".onResetFilters" />
                    </FlexBox>
                    <MessageStrip
                        class="ze4MessageStrip"
                        visible="{flow1>/warningVisible}"
                        text="{flow1>/warningText}"
                        type="Warning"
                        showIcon="true" />
                </VBox>

                <FlexBox class="ze4AllocationKpiGrid" wrap="Wrap" items="{flow1>/kpis}">
                    <VBox class="ze4KpiCard ze4AllocationKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="{flow1>icon}" class="ze4KpiIcon" color="{flow1>iconColor}" backgroundColor="{flow1>iconBackground}" />
                            <VBox class="ze4KpiText">
                                <Text class="ze4KpiTitle" text="{flow1>title}" />
                                <ObjectStatus class="ze4KpiValueStatus" text="{flow1>valueText}" state="{flow1>valueState}" tooltip="{flow1>valueText}" />
                            </VBox>
                        </HBox>
                        <ObjectStatus class="ze4KpiSub" text="{flow1>subText}" state="{flow1>state}" />
                    </VBox>
                </FlexBox>

                <VBox class="ze4Card ze4AllocationSankeyCard ze4AllocationLandingSankeyCard">
                    <HBox class="ze4CardHeader" alignItems="Center">
                        <Title text="선택 CCG 내부 코스트센터 흐름" level="H3" />
                        <ToolbarSpacer />
                        <Text class="ze4CardUnit" text="금액 단위: KRW" />
                    </HBox>
                    <ScrollContainer
                        horizontal="true"
                        vertical="true"
                        focusable="false"
                        class="ze4SankeyScroll ze4SankeyScrollCompact">
                        <core:HTML content="{flow1>/sankeyHtml}" sanitizeContent="false" />
                    </ScrollContainer>
                    <VBox class="ze4ChartEmptyState" visible="{= !${flow1>/hasFlowData} }">
                        <Text text="조회 조건에 해당하는 배부 데이터가 없습니다." />
                    </VBox>
                </VBox>

                <HBox class="ze4AllocationLandingLowerGrid">
                    <VBox class="ze4Card ze4TableCard ze4AllocationLandingTableCard">
                        <HBox class="ze4CardHeader" alignItems="Center">
                            <Title text="선택 CCG 내부 수령처 요약" level="H3" />
                        </HBox>
                        <t:Table
                            rows="{flow1>/receiverRows}"
                            selectionMode="Single"
                            selectionBehavior="Row"
                            rowSelectionChange=".onReceiverRowSelection"
                            visibleRowCount="7"
                            width="100%"
                            noData="조회 조건에 해당하는 배부 데이터가 없습니다."
                            class="ze4GridTable ze4Table ze4AllocationDetailTable">
                            <t:columns>
                                <t:Column width="16rem"><Label text="최종 수령 코스트센터" /><t:template><Text text="{flow1>receiverText}" wrapping="false" tooltip="{flow1>receiverText}" class="ze4NoWrapText" /></t:template></t:Column>
                                <t:Column width="12rem" hAlign="End"><Label text="외부 유입금액" /><t:template><Text text="{path: 'flow1>externalAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText" /></t:template></t:Column>
                                <t:Column width="12rem" hAlign="End"><Label text="내부 재배부금액" /><t:template><Text text="{path: 'flow1>internalAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText" /></t:template></t:Column>
                                <t:Column width="7rem" hAlign="End"><Label text="비중" /><t:template><Text text="{flow1>ratioText}" textAlign="End" wrapping="false" /></t:template></t:Column>
                                <t:Column width="14rem"><Label text="주요 세그먼트" /><t:template><Text text="{flow1>segmentText}" wrapping="false" tooltip="{flow1>segmentText}" class="ze4NoWrapText" /></t:template></t:Column>
                                <t:Column width="8rem" hAlign="End"><Label text="전표 건수" /><t:template><Text text="{flow1>documentCountText}" textAlign="End" wrapping="false" /></t:template></t:Column>
                            </t:columns>
                        </t:Table>
                    </VBox>

                    <VBox class="ze4Card ze4AllocationHelpPanel ze4AllocationLandingHelpPanel">
                        <HBox class="ze4CardHeader" alignItems="Center">
                            <Title text="화면 해석" level="H3" />
                        </HBox>
                        <MessageStrip text="{flow1>/explanationText}" type="Information" showIcon="true" />
                        <VBox class="ze4DetailList ze4AllocationSelectedReceiver">
                            <Label text="선택 코스트센터" class="ze4DetailLabel" />
                            <Text text="{flow1>/selectedReceiver/receiverText}" class="ze4DetailValue" wrapping="true" />
                            <Label text="외부 유입금액" class="ze4DetailLabel" />
                            <Text text="{path: 'flow1>/selectedReceiver/externalAmount', formatter: '.formatter.amount'}" class="ze4DetailValue ze4DetailAmount" wrapping="true" />
                            <Label text="내부 재배부금액" class="ze4DetailLabel" />
                            <Text text="{path: 'flow1>/selectedReceiver/internalAmount', formatter: '.formatter.amount'}" class="ze4DetailValue ze4DetailAmount" wrapping="true" />
                            <Label text="비중" class="ze4DetailLabel" />
                            <Text text="{flow1>/selectedReceiver/ratioText}" class="ze4DetailValue" wrapping="true" />
                            <Label text="전표 건수" class="ze4DetailLabel" />
                            <Text text="{flow1>/selectedReceiver/documentCountText}" class="ze4DetailValue" wrapping="true" />
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
