<mvc:View
    controllerName="ZE4_CC_COST.controller.DepartmentDetail"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:t="sap.ui.table"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds"
    xmlns:vizData="sap.viz.ui5.data">
    <mvc:dependents>
        <Dialog
            id="orgValueHelpDialog"
            class="ze4ValueHelpDialog"
            title="조직/코스트센터 선택"
            contentWidth="54rem"
            contentHeight="38rem"
            draggable="true"
            resizable="true"
            stretchOnPhone="true">
            <VBox class="ze4ValueHelpContent">
                <SearchField
                    width="100%"
                    placeholder="조직명, 코드, 책임자 검색"
                    liveChange=".onOrgValueHelpSearch"
                    search=".onOrgValueHelpSearch" />
                <t:TreeTable
                    id="orgValueHelpTree"
                    class="ze4TreeTable ze4ValueHelpTree"
                    rows="{path: 'department>/orgOptionTreeRows', parameters: {arrayNames: ['children']}}"
                    selectionMode="Single"
                    selectionBehavior="Row"
                    visibleRowCount="13"
                    width="100%"
                    expandFirstLevel="true"
                    enableColumnReordering="false"
                    noData="조직/코스트센터 데이터가 없습니다.">
                    <t:columns>
                        <t:Column width="20rem">
                            <Label text="조직/코스트센터명" />
                            <t:template>
                                <HBox class="ze4TreeNodeCell" alignItems="Center">
                                    <core:Icon src="{department>icon}" class="{department>iconClass}" />
                                    <Text text="{department>nodeText}" wrapping="false" tooltip="{department>nodeText}" class="ze4NoWrapText" />
                                </HBox>
                            </t:template>
                        </t:Column>
                        <t:Column width="8rem"><Label text="코드" /><t:template><Text text="{department>childId}" wrapping="false" /></t:template></t:Column>
                        <t:Column width="5rem"><Label text="레벨" /><t:template><Text text="{department>levelText}" wrapping="false" /></t:template></t:Column>
                        <t:Column width="11rem"><Label text="책임자" /><t:template><Text text="{path: 'department>manager', formatter: '.formatter.empty'}" wrapping="false" tooltip="{department>manager}" class="ze4NoWrapText" /></t:template></t:Column>
                    </t:columns>
                </t:TreeTable>
            </VBox>
            <beginButton>
                <Button text="선택" type="Emphasized" press=".onOrgValueHelpConfirm" />
            </beginButton>
            <endButton>
                <Button text="닫기" press=".onOrgValueHelpCancel" />
            </endButton>
        </Dialog>
    </mvc:dependents>

    <Page
        class="ze4DynamicPage ze4DepartmentPage sapUiSizeCompact"
        showHeader="false"
        enableScrolling="true"
        busy="{department>/busy}"
        busyIndicatorDelay="0">
                <content>
                    <VBox class="ze4PageContent ze4DepartmentContent">
                        <HBox class="ze4PageTitleBar" alignItems="Center" wrap="Wrap">
                            <Title text="{department>/pageTitle}" level="H1" titleStyle="H1" class="ze4PageHeroTitle" />
                            <ToolbarSpacer />
                            <HBox class="ze4PageActions" alignItems="Center">
                                <Button text="대시보드" icon="sap-icon://home" type="Transparent" press=".onGoDashboard" />
                                <Button text="배부 분석" icon="sap-icon://business-objects-experience" type="Transparent" press=".onGoAllocationAnalysis" />
                                <Button text="조직도 탐색" icon="sap-icon://org-chart" type="Transparent" press=".onGoOrgExplorer" />
                            </HBox>
                        </HBox>
                        <VBox class="ze4DepartmentHeaderStack">
                            <VBox class="ze4Card ze4DepartmentObjectHeader">
                                <HBox alignItems="Start" class="ze4ObjectHeaderTop">
                                    <core:Icon src="sap-icon://org-chart" class="ze4ObjectHeaderIcon" />
                                    <VBox class="ze4ObjectHeaderText">
                                        <HBox alignItems="Center" wrap="Wrap">
                                            <Title text="{department>/header/title}" level="H2" class="ze4ObjectHeaderTitle" />
                                            <ObjectStatus text="정상" state="Success" class="ze4HeaderStatus" />
                                        </HBox>
                                        <HBox class="ze4ObjectFacts" wrap="Wrap">
                                            <ObjectAttribute title="코드" text="{department>/header/code}" />
                                            <ObjectAttribute title="책임자" text="{department>/header/manager}" />
                                            <ObjectAttribute title="조회기간" text="{department>/header/period}" />
                                            <ObjectAttribute title="범위" text="{department>/header/scopeText}" />
                                        </HBox>
                                    </VBox>
                                </HBox>
                            </VBox>

                            <VBox class="ze4FilterBar ze4ObjectFilter">
                                <HBox class="ze4FilterHeader" alignItems="Center">
                                    <Title text="조회 조건" level="H3" />
                                    <ToolbarSpacer />
                                    <Button text="{department>/filterToggleText}" type="Transparent" press=".onToggleFilter" />
                                </HBox>
                                <FlexBox class="ze4FilterFields" visible="{department>/filterVisible}" wrap="Wrap" alignItems="End">
                                    <VBox class="ze4FilterField">
                                        <Label text="회사코드" />
                                        <Input value="{department>/filters/bukrs}" editable="false" enabled="false" class="ze4FixedInput" width="9rem" />
                                    </VBox>
                                    <VBox class="ze4FilterField ze4FilterFieldWide">
                                        <Label text="손익센터/부서 또는 코스트센터" />
                                        <Input value="{department>/filters/orgNodeText}" showValueHelp="true" valueHelpOnly="true" valueHelpRequest=".onOpenOrgValueHelp" placeholder="전체" width="17rem" />
                                    </VBox>
                                    <Button icon="sap-icon://decline" type="Transparent" tooltip="조직 선택 해제" press=".onClearOrgSelection" />
                                    <VBox class="ze4FilterField">
                                        <Label text="회계연도" required="true" />
                                        <Input value="{department>/filters/gjahr}" valueState="{department>/filterStates/gjahrState}" valueStateText="{department>/filterStates/gjahrStateText}" maxLength="4" width="8rem" />
                                    </VBox>
                                    <VBox class="ze4FilterField">
                                        <Label text="기간" required="true" />
                                        <Select selectedKey="{department>/filters/period}" valueState="{department>/filterStates/periodState}" valueStateText="{department>/filterStates/periodStateText}" items="{department>/periodOptions}" width="8rem">
                                            <core:Item key="{department>key}" text="{department>text}" />
                                        </Select>
                                    </VBox>
                                    <Button class="ze4SearchButton" text="검색" icon="sap-icon://search" type="Emphasized" press=".onSearch" />
                                    <Button text="초기화" type="Transparent" press=".onResetFilters" />
                                </FlexBox>
                                <MessageStrip class="ze4MessageStrip" visible="{department>/warningVisible}" text="{department>/warningText}" type="Warning" showIcon="true" />
                            </VBox>
                        </VBox>

                        <FlexBox class="ze4KpiGrid" wrap="Wrap" items="{department>/kpis}">
                            <VBox class="ze4KpiCard">
                                <HBox alignItems="Center">
                                    <core:Icon src="{department>icon}" class="ze4KpiIcon" color="{department>iconColor}" backgroundColor="{department>iconBackground}" />
                                    <VBox class="ze4KpiText">
                                        <Text class="ze4KpiTitle" text="{department>title}" />
                                        <ObjectStatus class="ze4KpiValueStatus" text="{department>valueText}" state="{department>valueState}" />
                                    </VBox>
                                </HBox>
                                <ObjectStatus class="ze4KpiSub" text="{department>subText}" state="{department>state}" />
                            </VBox>
                        </FlexBox>

                        <HBox class="ze4ChartGrid">
                            <VBox class="ze4Card ze4ChartCard ze4DepartmentTrendPanel">
                                <HBox class="ze4CardHeader" alignItems="Center">
                                    <Title text="월별 비용 추이" level="H3" />
                                    <ToolbarSpacer />
                                    <Text class="ze4CardUnit" text="단위: KRW" />
                                </HBox>
                                <viz:VizFrame id="departmentTrendChart" height="20rem" width="100%" vizType="line" uiConfig="{applicationSet:'fiori'}" visible="{department>/hasTrendData}" selectData=".onTrendChartSelectData">
                                    <viz:dataset>
                                        <vizData:FlattenedDataset data="{department>/monthlyTrend}">
                                            <vizData:dimensions>
                                                <vizData:DimensionDefinition name="조회 월" value="{department>monthText}" />
                                            </vizData:dimensions>
                                            <vizData:measures>
                                                <vizData:MeasureDefinition name="실적" value="{department>actualAmount}" />
                                                <vizData:MeasureDefinition name="예산" value="{department>budgetAmount}" />
                                            </vizData:measures>
                                        </vizData:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="실적,예산" />
                                        <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="조회 월" />
                                    </viz:feeds>
                                    <viz:dependents>
                                        <viz:Popover id="departmentTrendChartPopover" />
                                    </viz:dependents>
                                </viz:VizFrame>
                                <VBox class="ze4ChartEmptyState" visible="{= !${department>/hasTrendData} }">
                                    <Text text="월별 비용 데이터가 없습니다." />
                                </VBox>
                                <VBox class="ze4ChartSelectionInfo" visible="{department>/hasSelectedMonthSummary}">
                                    <Title text="선택 월 요약" level="H4" />
                                    <FlexBox class="ze4SelectionFacts" wrap="Wrap">
                                        <ObjectAttribute title="선택 월" text="{department>/selectedMonthSummary/monthText}" />
                                        <ObjectAttribute title="실적 비용" text="{path: 'department>/selectedMonthSummary/actualAmount', formatter: '.formatter.amountWithCurrency'}" />
                                        <ObjectAttribute title="예산" text="{path: 'department>/selectedMonthSummary/budgetAmount', formatter: '.formatter.amountWithCurrency'}" />
                                        <ObjectAttribute title="전월대비" text="{path: 'department>/selectedMonthSummary/momAmount', formatter: '.formatter.amountWithCurrency'}" />
                                        <ObjectAttribute title="전표 건수" text="{= ${department>/selectedMonthSummary/documentCount} + '건' }" />
                                    </FlexBox>
                                </VBox>
                            </VBox>

                            <VBox class="ze4Card ze4ChartCard ze4DepartmentCompositionPanel">
                                <HBox class="ze4CardHeader" alignItems="Center">
                                    <Title text="비용계정별 구성" level="H3" />
                                    <ToolbarSpacer />
                                    <Text class="ze4CardUnit" text="단위: KRW" />
                                </HBox>
                                <viz:VizFrame id="departmentCompositionChart" height="22rem" width="100%" vizType="donut" uiConfig="{applicationSet:'fiori'}" visible="{department>/hasCompositionData}" selectData=".onCompositionChartSelectData">
                                    <viz:dataset>
                                        <vizData:FlattenedDataset data="{department>/accountComposition}">
                                            <vizData:dimensions>
                                                <vizData:DimensionDefinition name="계정명" value="{department>accountLabel}" />
                                            </vizData:dimensions>
                                            <vizData:measures>
                                                <vizData:MeasureDefinition name="금액" value="{department>amount}" />
                                            </vizData:measures>
                                        </vizData:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <vizFeeds:FeedItem uid="size" type="Measure" values="금액" />
                                        <vizFeeds:FeedItem uid="color" type="Dimension" values="계정명" />
                                    </viz:feeds>
                                    <viz:dependents>
                                        <viz:Popover id="departmentCompositionChartPopover" />
                                    </viz:dependents>
                                </viz:VizFrame>
                                <VBox class="ze4ChartEmptyState" visible="{= !${department>/hasCompositionData} }">
                                    <Text text="비용계정 구성 데이터가 없습니다." />
                                </VBox>
                                <VBox class="ze4ChartSelectionInfo" visible="{department>/hasSelectedAccountSummary}">
                                    <HBox alignItems="Center">
                                        <Title text="선택 계정 요약" level="H4" />
                                        <ToolbarSpacer />
                                        <Button text="전표 상세" type="Transparent" icon="sap-icon://navigation-right-arrow" press=".onGoSelectedAccountDocuments" enabled="{= ${department>/selectedAccountSummary/saknr} !== 'ETC' }" />
                                    </HBox>
                                    <FlexBox class="ze4SelectionFacts" wrap="Wrap">
                                        <ObjectAttribute title="선택 계정" text="{department>/selectedAccountSummary/accountLabel}" />
                                        <ObjectAttribute title="금액" text="{path: 'department>/selectedAccountSummary/amount', formatter: '.formatter.amountWithCurrency'}" />
                                        <ObjectAttribute title="비율" text="{path: 'department>/selectedAccountSummary/ratio', formatter: '.formatter.rate'}" />
                                        <ObjectAttribute title="전표 건수" text="{= ${department>/selectedAccountSummary/documentCount} + '건' }" />
                                    </FlexBox>
                                </VBox>
                            </VBox>
                        </HBox>

                        <VBox>
                            <HBox class="ze4CardHeader" alignItems="Center">
                                <Title text="하위 코스트센터 현황" level="H3" />
                                <ToolbarSpacer />
                                <Text class="ze4CardUnit" text="단위: KRW" />
                            </HBox>
                            <t:Table rows="{department>/childCostCenterRows}" selectionMode="Single" selectionBehavior="Row" rowSelectionChange=".onChildRowSelection" visibleRowCount="6" width="100%" fixedColumnCount="2">
                                <t:columns>
                                    <t:Column width="4.5rem"><Label text="순위" /><t:template><Text text="{department>rank}" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="8rem"><Label text="코스트센터" /><t:template><Text text="{department>kostl}" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="14rem"><Label text="코스트센터명" /><t:template><Text text="{department>kostlTxt}" wrapping="false" tooltip="{department>kostlTxt}" /></t:template></t:Column>
                                    <t:Column width="10rem"><Label text="책임자" /><t:template><Text text="{department>manager}" wrapping="false" tooltip="{department>manager}" /></t:template></t:Column>
                                    <t:Column width="11rem" hAlign="End"><Label text="누적비용" /><t:template><Text text="{path: 'department>actualAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="11rem" hAlign="End"><Label text="이번달비용" /><t:template><Text text="{path: 'department>currentAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="11rem" hAlign="End"><Label text="전월비용" /><t:template><Text text="{path: 'department>previousAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="10rem" hAlign="End"><Label text="전월대비" /><t:template><ObjectStatus text="{path: 'department>momAmount', formatter: '.formatter.amount'}" state="{department>momState}" /></t:template></t:Column>
                                    <t:Column width="11rem" hAlign="End"><Label text="예산" /><t:template><Text text="{path: 'department>budgetAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="11rem" hAlign="End"><Label text="차이" /><t:template><ObjectStatus text="{path: 'department>varianceAmount', formatter: '.formatter.amount'}" state="{department>varianceState}" /></t:template></t:Column>
                                    <t:Column width="8rem" hAlign="End"><Label text="예산대비" /><t:template><ObjectStatus text="{path: 'department>varianceRate', formatter: '.formatter.rate'}" state="{department>varianceState}" /></t:template></t:Column>
                                    <t:Column width="8rem" hAlign="End"><Label text="전표건수" /><t:template><Text text="{path: 'department>documentCount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="7rem"><Label text="상태" /><t:template><ObjectStatus text="{department>statusText}" state="{department>statusState}" /></t:template></t:Column>
                                </t:columns>
                            </t:Table>
                        </VBox>

                        <VBox>
                            <HBox class="ze4CardHeader" alignItems="Center">
                                <Title text="비용계정별 상세 현황" level="H3" />
                                <HBox class="ze4TableHeaderMetric" alignItems="Center">
                                    <Text class="ze4TableHeaderMetricLabel" text="이번달 합계" />
                                    <Text class="ze4TableHeaderMetricValue" text="{path: 'department>/accountSummary/currentAmount', formatter: '.formatter.amountWithCurrency'}" />
                                </HBox>
                                <ToolbarSpacer />
                                <Text class="ze4CardUnit" text="단위: KRW" />
                            </HBox>
                            <t:Table rows="{department>/accountRows}" selectionMode="Single" selectionBehavior="Row" rowSelectionChange=".onAccountRowSelection" visibleRowCount="6" width="100%" fixedColumnCount="2">
                                <t:columns>
                                    <t:Column width="4.5rem"><Label text="순위" /><t:template><Text text="{department>rank}" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="8rem"><Label text="G/L 계정" /><t:template><Text text="{department>saknr}" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="14rem"><Label text="계정명" /><t:template><Text text="{department>saknrTxt}" wrapping="false" tooltip="{department>saknrTxt}" /></t:template></t:Column>
                                    <t:Column width="13rem"><Label text="계정그룹" /><t:template><Text text="{department>ktoksTxt}" wrapping="false" tooltip="{department>ktoksTxt}" /></t:template></t:Column>
                                    <t:Column width="11rem" hAlign="End"><Label text="누적비용" /><t:template><Text text="{path: 'department>actualAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="11rem" hAlign="End"><Label text="이번달비용" /><t:template><Text text="{path: 'department>currentAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="11rem" hAlign="End"><Label text="전월비용" /><t:template><Text text="{path: 'department>previousAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="11rem" hAlign="End"><Label text="예산" /><t:template><Text text="{path: 'department>budgetAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="11rem" hAlign="End"><Label text="차이" /><t:template><ObjectStatus text="{path: 'department>varianceAmount', formatter: '.formatter.amount'}" state="{department>varianceState}" /></t:template></t:Column>
                                    <t:Column width="8rem" hAlign="End"><Label text="예산대비" /><t:template><ObjectStatus text="{path: 'department>varianceRate', formatter: '.formatter.rate'}" state="{department>varianceState}" /></t:template></t:Column>
                                    <t:Column width="10rem" hAlign="End"><Label text="전월대비" /><t:template><ObjectStatus text="{path: 'department>momAmount', formatter: '.formatter.amount'}" state="{department>momState}" /></t:template></t:Column>
                                    <t:Column width="8rem" hAlign="End"><Label text="전표건수" /><t:template><Text text="{path: 'department>documentCount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" /></t:template></t:Column>
                                    <t:Column width="7rem" hAlign="End"><Label text="비율" /><t:template><Text text="{path: 'department>ratio', formatter: '.formatter.rate'}" textAlign="End" wrapping="false" /></t:template></t:Column>
                                </t:columns>
                            </t:Table>
                        </VBox>
                    </VBox>
                </content>
    </Page>
</mvc:View>
