<mvc:View
    controllerName="ZE4_CC_COST.controller.DocumentDetail"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:t="sap.ui.table">
    <mvc:dependents>
        <Dialog
            id="orgValueHelpDialog"
            class="ze4ValueHelpDialog"
            title="조직/코스트센터 선택"
            contentWidth="54rem"
            contentHeight="38rem"
            draggable="true"
            resizable="true"
            stretchOnPhone="true">
            <VBox class="ze4ValueHelpContent">
                <SearchField
                    width="100%"
                    placeholder="조직명, 코드, 책임자 검색"
                    liveChange=".onOrgValueHelpSearch"
                    search=".onOrgValueHelpSearch" />
                <t:TreeTable
                    id="orgValueHelpTree"
                    class="ze4TreeTable ze4ValueHelpTree"
                    rows="{path: 'document>/orgOptionTreeRows', parameters: {arrayNames: ['children']}}"
                    selectionMode="Single"
                    selectionBehavior="Row"
                    visibleRowCount="13"
                    width="100%"
                    expandFirstLevel="true"
                    enableColumnReordering="false"
                    noData="조직/코스트센터 데이터가 없습니다.">
                    <t:columns>
                        <t:Column width="20rem">
                            <Label text="조직/코스트센터명" />
                            <t:template>
                                <HBox class="ze4TreeNodeCell" alignItems="Center">
                                    <core:Icon src="{document>icon}" class="{document>iconClass}" />
                                    <Text text="{document>nodeText}" wrapping="false" tooltip="{document>nodeText}" class="ze4NoWrapText" />
                                </HBox>
                            </t:template>
                        </t:Column>
                        <t:Column width="8rem"><Label text="코드" /><t:template><Text text="{document>childId}" wrapping="false" /></t:template></t:Column>
                        <t:Column width="5rem"><Label text="레벨" /><t:template><Text text="{document>levelText}" wrapping="false" /></t:template></t:Column>
                        <t:Column width="11rem"><Label text="책임자" /><t:template><Text text="{path: 'document>manager', formatter: '.formatter.empty'}" wrapping="false" tooltip="{document>manager}" class="ze4NoWrapText" /></t:template></t:Column>
                    </t:columns>
                </t:TreeTable>
            </VBox>
            <beginButton>
                <Button text="선택" type="Emphasized" press=".onOrgValueHelpConfirm" />
            </beginButton>
            <endButton>
                <Button text="닫기" press=".onOrgValueHelpCancel" />
            </endButton>
        </Dialog>
        <Dialog
            id="accountValueHelpDialog"
            class="ze4ValueHelpDialog"
            title="G/L 계정 선택"
            contentWidth="44rem"
            contentHeight="34rem"
            draggable="true"
            resizable="true"
            stretchOnPhone="true">
            <VBox class="ze4ValueHelpContent">
                <SearchField
                    width="100%"
                    placeholder="계정코드 또는 계정명 검색"
                    liveChange=".onAccountValueHelpSearch"
                    search=".onAccountValueHelpSearch" />
                <Table
                    id="accountValueHelpTable"
                    class="ze4AccountValueHelpTable"
                    mode="SingleSelectMaster"
                    selectionChange=".onAccountValueHelpConfirm"
                    items="{document>/accountValueHelpFilteredRows}"
                    growing="true"
                    growingThreshold="30"
                    noDataText="선택 가능한 G/L 계정이 없습니다.">
                    <columns>
                        <Column width="8rem"><Text text="G/L 계정" /></Column>
                        <Column width="14rem"><Text text="계정명" /></Column>
                        <Column><Text text="계정그룹" /></Column>
                    </columns>
                    <ColumnListItem type="Active" press=".onAccountValueHelpConfirm">
                        <cells>
                            <Text text="{document>saknr}" wrapping="false" />
                            <Text text="{document>saknrTxt}" wrapping="false" tooltip="{document>saknrTxt}" class="ze4NoWrapText" />
                            <Text text="{document>ktoksTxt}" wrapping="false" tooltip="{document>ktoksTxt}" class="ze4NoWrapText" />
                        </cells>
                    </ColumnListItem>
                </Table>
            </VBox>
            <endButton>
                <Button text="닫기" press=".onAccountValueHelpCancel" />
            </endButton>
        </Dialog>
    </mvc:dependents>

    <f:DynamicPage
        class="ze4DynamicPage sapUiSizeCompact"
        fitContent="true"
        busy="{document>/busy}"
        busyIndicatorDelay="0">
                <f:title>
                    <f:DynamicPageTitle>
                        <f:heading>
                            <VBox>
                                <HBox class="ze4Breadcrumb" alignItems="Center">
                                    <Link text="홈" press=".onGoDashboard" />
                                    <core:Icon src="sap-icon://slim-arrow-right" />
                                    <Link text="부서별 비용분석" press=".onGoDashboard" />
                                    <core:Icon src="sap-icon://slim-arrow-right" />
                                    <Text text="전표 상세" />
                                </HBox>
                                <Title text="{document>/pageTitle}" level="H2" class="ze4PageTitle" />
                            </VBox>
                        </f:heading>
                    </f:DynamicPageTitle>
                </f:title>

                <f:header>
                    <f:DynamicPageHeader pinnable="false">
                        <VBox class="ze4FilterBar">
                            <FlexBox class="ze4FilterFields" wrap="Wrap" alignItems="End">
                                <VBox class="ze4FilterField">
                                    <Label text="회사코드" />
                                    <Input value="{document>/filters/bukrs}" editable="false" enabled="false" class="ze4FixedInput" width="9rem" />
                                </VBox>
                                <VBox class="ze4FilterField">
                                    <Label text="회계연도" required="true" />
                                    <Input value="{document>/filters/gjahr}" valueState="{document>/filterStates/gjahrState}" valueStateText="{document>/filterStates/gjahrStateText}" maxLength="4" width="8rem" />
                                </VBox>
                                <VBox class="ze4FilterField">
                                    <Label text="기간" required="true" />
                                    <Select selectedKey="{document>/filters/period}" valueState="{document>/filterStates/periodState}" valueStateText="{document>/filterStates/periodStateText}" items="{document>/periodOptions}" width="8rem">
                                        <core:Item key="{document>key}" text="{document>text}" />
                                    </Select>
                                </VBox>
                                <VBox class="ze4FilterField ze4FilterFieldWide">
                                    <Label text="조직/코스트센터" />
                                    <Input value="{document>/filters/orgNodeText}" showValueHelp="true" valueHelpOnly="true" valueHelpRequest=".onOpenOrgValueHelp" placeholder="전체" width="17rem" />
                                </VBox>
                                <Button icon="sap-icon://decline" type="Transparent" tooltip="조직 선택 해제" press=".onClearOrgSelection" />
                                <VBox class="ze4FilterField">
                                    <Label text="G/L 계정" />
                                    <Input
                                        value="{document>/accountFilterText}"
                                        showValueHelp="true"
                                        valueHelpOnly="true"
                                        valueHelpRequest=".onOpenAccountValueHelp"
                                        placeholder="전체"
                                        width="12rem" />
                                </VBox>
                                <Button icon="sap-icon://decline" type="Transparent" tooltip="계정 선택 해제" press=".onClearAccountSelection" />
                                <Button class="ze4SearchButton" text="검색" icon="sap-icon://search" type="Emphasized" press=".onSearch" />
                                <Button text="초기화" type="Transparent" press=".onResetFilters" />
                            </FlexBox>
                            <MessageStrip class="ze4MessageStrip" visible="{document>/warningVisible}" text="{document>/warningText}" type="Warning" showIcon="true" />
                        </VBox>
                    </f:DynamicPageHeader>
                </f:header>

                <f:content>
                    <VBox class="ze4PageContent">
                        <VBox class="ze4Card ze4DocumentHeader">
                            <HBox wrap="Wrap" class="ze4ObjectFacts">
                                <ObjectAttribute title="조직/코스트센터" text="{document>/header/orgText}" />
                                <ObjectAttribute title="코드" text="{document>/header/orgCode}" />
                                <ObjectAttribute title="계정" text="{document>/header/account}" />
                                <ObjectAttribute title="계정명" text="{document>/header/accountText}" />
                                <ObjectAttribute title="조회기간" text="{document>/header/period}" />
                                <ObjectAttribute title="라인건수" text="{document>/header/lineCountText}" />
                            </HBox>
                        </VBox>

                        <FlexBox class="ze4KpiGrid" wrap="Wrap" items="{document>/kpis}">
                            <VBox class="ze4KpiCard">
                                <HBox alignItems="Start">
                                    <VBox class="ze4KpiText">
                                        <Text class="ze4KpiTitle" text="{document>title}" />
                                        <Text class="ze4KpiValue" text="{document>valueText}" />
                                    </VBox>
                                </HBox>
                                <ObjectStatus class="ze4KpiSub" text="{document>subText}" state="{document>state}" />
                            </VBox>
                        </FlexBox>

                        <HBox class="ze4DocumentMain">
                            <VBox class="ze4Card ze4DocumentTableCard">
                                <HBox class="ze4CardHeader" alignItems="Center">
                                    <Title text="전표라인 상세 내역" level="H3" />
                                    <ToolbarSpacer />
                                    <Text class="ze4CardUnit" text="단위: KRW" />
                                </HBox>
                                <t:Table
                                    id="documentTable"
                                    rows="{document>/documentRows}"
                                    selectionMode="Single"
                                    selectionBehavior="Row"
                                    rowSelectionChange=".onDocumentRowSelection"
                                    visibleRowCount="12"
                                    width="100%"
                                    fixedColumnCount="3"
                                    enableColumnReordering="true"
                                    class="ze4GridTable ze4Table ze4DocumentTable">
                                    <t:columns>
                                        <t:Column width="8rem"><Label text="전기일자" /><t:template><Text text="{path: 'document>Budat', formatter: '.formatter.date'}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="10rem"><Label text="전표번호" /><t:template><Text text="{document>Belnr}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="5rem"><Label text="라인" /><t:template><Text text="{document>Docln}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="6rem"><Label text="전표유형" /><t:template><Text text="{document>Blart}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="10rem"><Label text="전표유형명" /><t:template><Text text="{document>BlartTxt}" wrapping="false" tooltip="{document>BlartTxt}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="9rem"><Label text="비용흐름" /><t:template><ObjectStatus text="{document>CostFlowTypeTxt}" state="{path: 'document>CostFlowTypeTxt', formatter: '.formatter.costFlowTypeState'}" /></t:template></t:Column>
                                        <t:Column width="7rem"><Label text="차대변" /><t:template><Text text="{parts: [{path: 'document>Drcrk'}, {path: 'document>DrcrkTxt'}], formatter: '.formatter.drcrkText'}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="8rem"><Label text="분석 코스트센터" /><t:template><Text text="{document>Kostl}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="13rem"><Label text="분석 코스트센터명" /><t:template><Text text="{document>KostlTxt}" wrapping="false" tooltip="{document>KostlTxt}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="8rem"><Label text="G/L 계정" /><t:template><Text text="{document>Saknr}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="13rem"><Label text="계정명" /><t:template><Text text="{document>SaknrTxt}" wrapping="false" tooltip="{document>SaknrTxt}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="13rem"><Label text="계정그룹" /><t:template><Text text="{document>KtoksTxt}" wrapping="false" tooltip="{document>KtoksTxt}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="10rem"><Label text="거래처" /><t:template><Text text="{document>Partner}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="13rem"><Label text="거래처명" /><t:template><Text text="{document>PartnerName}" wrapping="false" tooltip="{document>PartnerName}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="16rem"><Label text="적요" /><t:template><Text text="{document>Sgtxt}" wrapping="false" tooltip="{document>Sgtxt}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="10rem"><Label text="참조번호" /><t:template><Text text="{document>Xblnr}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="11rem" hAlign="End"><Label text="금액" /><t:template><Text text="{path: 'document>Amount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText" /></t:template></t:Column>
                                        <t:Column width="5rem"><Label text="통화" /><t:template><Text text="{document>Waers}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="10rem"><Label text="송신 코스트센터" /><t:template><Text text="{path: 'document>SenderKostl', formatter: '.formatter.empty'}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="13rem"><Label text="송신 코스트센터명" /><t:template><Text text="{path: 'document>SenderKostlTxt', formatter: '.formatter.empty'}" wrapping="false" tooltip="{document>SenderKostlTxt}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="10rem"><Label text="수신 코스트센터" /><t:template><Text text="{path: 'document>ReceiverKostl', formatter: '.formatter.empty'}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="13rem"><Label text="수신 코스트센터명" /><t:template><Text text="{path: 'document>ReceiverKostlTxt', formatter: '.formatter.empty'}" wrapping="false" tooltip="{document>ReceiverKostlTxt}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="9rem"><Label text="수신 프로핏센터" /><t:template><Text text="{path: 'document>ReceiverPrctr', formatter: '.formatter.empty'}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="12rem"><Label text="수신 프로핏센터명" /><t:template><Text text="{path: 'document>ReceiverPrctrTxt', formatter: '.formatter.empty'}" wrapping="false" tooltip="{document>ReceiverPrctrTxt}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="9rem"><Label text="구매오더" /><t:template><Text text="{document>Ebeln}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="9rem"><Label text="자재문서" /><t:template><Text text="{document>Mblnr}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="9rem"><Label text="SD문서" /><t:template><Text text="{document>Vbeln}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="9rem"><Label text="생산오더" /><t:template><Text text="{document>Aufnr}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="8rem"><Label text="상태" /><t:template><ObjectStatus text="{path: 'document>BstatTxt', formatter: '.formatter.empty'}" state="{path: 'document>BstatTxt', formatter: '.formatter.documentStatus'}" /></t:template></t:Column>
                                    </t:columns>
                                </t:Table>
                            </VBox>

                            <VBox class="ze4Card ze4DocumentDetailPanel">
                                <HBox class="ze4CardHeader" alignItems="Center">
                                    <Title text="선택 전표 정보" level="H3" />
                                </HBox>
                                <VBox visible="{document>/hasSelection}" class="ze4DetailList">
                                    <Label text="전표번호" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Belnr', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="전표라인" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Docln', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="전표유형" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Blart', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="전표유형명" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/BlartTxt', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="전기일자" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Budat', formatter: '.formatter.date'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="증빙일자" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Bldat', formatter: '.formatter.date'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="헤더텍스트" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Bktxt', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="품목텍스트" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Sgtxt', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="참조번호" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Xblnr', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="거래처" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Partner', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="거래처명" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/PartnerName', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="G/L 계정" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Saknr', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="계정명" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/SaknrTxt', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="분석 코스트센터" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Kostl', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="분석 코스트센터명" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/KostlTxt', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="송신 코스트센터" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/SenderKostl', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="송신 코스트센터명" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/SenderKostlTxt', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="수신 코스트센터" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/ReceiverKostl', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="수신 코스트센터명" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/ReceiverKostlTxt', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="수신 프로핏센터" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/ReceiverPrctr', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="수신 프로핏센터명" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/ReceiverPrctrTxt', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="비용흐름유형" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/CostFlowTypeTxt', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="차대변" class="ze4DetailLabel" /><Text text="{parts: [{path: 'document>/selectedDocument/Drcrk'}, {path: 'document>/selectedDocument/DrcrkTxt'}], formatter: '.formatter.drcrkText'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="금액" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Amount', formatter: '.formatter.amountWithCurrency'}" class="ze4DetailValue ze4DetailAmount" wrapping="true" />
                                    <Label text="통화" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Waers', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="구매오더" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Ebeln', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="자재문서" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Mblnr', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="SD문서" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Vbeln', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                    <Label text="생산오더" class="ze4DetailLabel" /><Text text="{path: 'document>/selectedDocument/Aufnr', formatter: '.formatter.empty'}" class="ze4DetailValue" wrapping="true" />
                                </VBox>
                                <IllustratedMessage
                                    visible="{= !${document>/hasSelection} }"
                                    illustrationType="sapIllus-NoData"
                                    title="선택된 전표가 없습니다."
                                    description="전표라인을 선택하면 상세 정보가 표시됩니다." />
                            </VBox>
                        </HBox>
                    </VBox>
                </f:content>
    </f:DynamicPage>
</mvc:View>
