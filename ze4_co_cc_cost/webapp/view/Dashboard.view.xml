<mvc:View
    controllerName="ZE4_CC_COST.controller.Dashboard"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:t="sap.ui.table"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds"
    xmlns:vizData="sap.viz.ui5.data">
    <mvc:dependents>
        <Dialog
            id="orgValueHelpDialog"
            class="ze4ValueHelpDialog"
            title="조직/코스트센터 선택"
            contentWidth="54rem"
            contentHeight="38rem"
            draggable="true"
            resizable="true"
            stretchOnPhone="true">
            <VBox class="ze4ValueHelpContent">
                <SearchField
                    width="100%"
                    placeholder="조직명, 코드, 책임자 검색"
                    liveChange=".onOrgValueHelpSearch"
                    search=".onOrgValueHelpSearch" />
                <t:TreeTable
                    id="orgValueHelpTree"
                    class="ze4TreeTable ze4ValueHelpTree"
                    rows="{path: 'dashboard>/orgOptionTreeRows', parameters: {arrayNames: ['children']}}"
                    selectionMode="Single"
                    selectionBehavior="Row"
                    visibleRowCount="13"
                    width="100%"
                    expandFirstLevel="true"
                    enableColumnReordering="false"
                    noData="조직/코스트센터 데이터가 없습니다.">
                    <t:columns>
                        <t:Column width="20rem">
                            <Label text="조직/코스트센터명" />
                            <t:template>
                                <HBox class="ze4TreeNodeCell" alignItems="Center">
                                    <core:Icon src="{dashboard>icon}" class="{dashboard>iconClass}" />
                                    <Text text="{dashboard>nodeText}" wrapping="false" tooltip="{dashboard>costCenterTooltip}" class="ze4NoWrapText" />
                                </HBox>
                            </t:template>
                        </t:Column>
                        <t:Column width="8rem"><Label text="코드" /><t:template><Text text="{dashboard>childId}" wrapping="false" /></t:template></t:Column>
                        <t:Column width="5rem"><Label text="레벨" /><t:template><Text text="{dashboard>levelText}" wrapping="false" /></t:template></t:Column>
                        <t:Column width="11rem"><Label text="책임자" /><t:template><Text text="{path: 'dashboard>manager', formatter: '.formatter.empty'}" wrapping="false" tooltip="{dashboard>manager}" class="ze4NoWrapText" /></t:template></t:Column>
                    </t:columns>
                </t:TreeTable>
            </VBox>
            <beginButton>
                <Button text="선택" type="Emphasized" press=".onOrgValueHelpConfirm" />
            </beginButton>
            <endButton>
                <Button text="닫기" press=".onOrgValueHelpCancel" />
            </endButton>
        </Dialog>
    </mvc:dependents>

    <Page
        class="ze4DynamicPage sapUiSizeCompact"
        showHeader="false"
        enableScrolling="true"
        busy="{dashboard>/busy}"
        busyIndicatorDelay="0">
                <content>
                    <VBox class="ze4PageContent">
                        <HBox class="ze4PageTitleBar" alignItems="Center" wrap="Wrap">
                            <Title text="{i18n>title}" level="H1" titleStyle="H1" class="ze4PageHeroTitle" />
                            <ToolbarSpacer />
                            <HBox class="ze4PageActions" alignItems="Center">
                                <Button text="대시보드" icon="sap-icon://home" type="Transparent" press=".onGoDashboard" />
                                <Button text="배부 분석" icon="sap-icon://business-objects-experience" type="Transparent" press=".onGoAllocationAnalysis" />
                                <Button text="Excel 다운로드" icon="sap-icon://excel-attachment" type="Transparent" press=".onExportExcel" />
                                <Button text="PDF 다운로드" icon="sap-icon://print" type="Transparent" press=".onExportPdf" />
                            </HBox>
                        </HBox>
                        <VBox class="ze4FilterBar">
                            <HBox class="ze4FilterHeader" alignItems="Center">
                                <Title text="조회 조건" level="H3" />
                                <ToolbarSpacer />
                                <Button text="{dashboard>/filterToggleText}" type="Transparent" press=".onToggleFilter" />
                            </HBox>
                            <FlexBox class="ze4FilterFields" visible="{dashboard>/filterVisible}" wrap="Wrap" alignItems="End">
                                <VBox class="ze4FilterField">
                                    <Label text="회사코드" />
                                    <Input value="{dashboard>/filters/bukrs}" editable="false" enabled="false" class="ze4FixedInput" width="9rem" />
                                </VBox>
                                <VBox class="ze4FilterField ze4FilterFieldWide">
                                    <Label text="조직/코스트센터" />
                                    <Input
                                        value="{dashboard>/filters/orgNodeText}"
                                        showValueHelp="true"
                                        valueHelpOnly="true"
                                        valueHelpRequest=".onOpenOrgValueHelp"
                                        placeholder="전체"
                                        width="17rem" />
                                </VBox>
                                <Button icon="sap-icon://decline" type="Transparent" tooltip="선택 해제" press=".onClearOrgSelection" />
                                <VBox class="ze4FilterField">
                                    <Label text="G/L 계정" />
                                    <Input
                                        value="{dashboard>/filters/saknr}"
                                        maxLength="10"
                                        placeholder="전체"
                                        width="9rem" />
                                </VBox>
                                <VBox class="ze4FilterField">
                                    <Label text="회계연도" required="true" />
                                    <Input
                                        value="{dashboard>/filters/gjahr}"
                                        valueState="{dashboard>/filterStates/gjahrState}"
                                        valueStateText="{dashboard>/filterStates/gjahrStateText}"
                                        maxLength="4"
                                        width="8rem" />
                                </VBox>
                                <VBox class="ze4FilterField">
                                    <Label text="기간" required="true" />
                                    <Select
                                        selectedKey="{dashboard>/filters/period}"
                                        valueState="{dashboard>/filterStates/periodState}"
                                        valueStateText="{dashboard>/filterStates/periodStateText}"
                                        items="{dashboard>/periodOptions}"
                                        width="8rem">
                                        <core:Item key="{dashboard>key}" text="{dashboard>text}" />
                                    </Select>
                                </VBox>
                                <Button class="ze4SearchButton" text="검색" icon="sap-icon://search" type="Emphasized" press=".onSearch" />
                                <Button text="초기화" type="Transparent" press=".onResetFilters" />
                            </FlexBox>
                            <MessageStrip
                                class="ze4MessageStrip"
                                visible="{dashboard>/warningVisible}"
                                text="{dashboard>/warningText}"
                                type="Warning"
                                showIcon="true" />
                        </VBox>

                        <FlexBox class="ze4KpiGrid" wrap="Wrap" items="{dashboard>/kpis}">
                            <VBox class="ze4KpiCard">
                                <HBox alignItems="Center">
                                    <core:Icon src="{dashboard>icon}" class="ze4KpiIcon" color="{dashboard>iconColor}" backgroundColor="{dashboard>iconBackground}" />
                                    <VBox class="ze4KpiText">
                                        <Text class="ze4KpiTitle" text="{dashboard>title}" />
                                        <ObjectStatus class="ze4KpiValueStatus" text="{dashboard>valueText}" state="{dashboard>valueState}" />
                                    </VBox>
                                </HBox>
                                <ObjectStatus class="ze4KpiSub" text="{dashboard>subText}" state="{dashboard>state}" />
                            </VBox>
                        </FlexBox>

                        <HBox class="ze4DashboardMainRow">
                            <VBox class="ze4Card ze4OrgRollupCard">
                                <HBox class="ze4CardHeader" alignItems="Center">
                                    <Title text="{dashboard>/hierarchyTitle}" level="H3" />
                                    <ToolbarSpacer />
                                    <Text class="ze4CardUnit" text="단위: KRW" />
                                </HBox>
                                <t:TreeTable
                                    id="orgRollupTree"
                                    class="ze4TreeTable ze4OrgTreeTable ze4Table"
                                    rows="{path: 'dashboard>/orgTreeRows', parameters: {arrayNames: ['children']}}"
                                    selectionMode="Single"
                                    selectionBehavior="Row"
                                    rowSelectionChange=".onOrgTreeRowSelection"
                                    visibleRowCount="9"
                                    width="100%"
                                    expandFirstLevel="true"
                                    enableColumnReordering="false"
                                    noData="계층별 집계 데이터가 없습니다.">
                                    <t:columns>
                                        <t:Column width="23rem">
                                            <Label text="{dashboard>/hierarchyNameLabel}" />
                                            <t:template>
                                                <HBox class="ze4TreeNodeCell" alignItems="Center">
                                                    <core:Icon src="{dashboard>icon}" class="{dashboard>iconClass}" />
                                                    <Text text="{dashboard>nodeText}" wrapping="false" tooltip="{dashboard>costCenterTooltip}" class="ze4NoWrapText" />
                                                </HBox>
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="9rem"><Label text="코드" /><t:template><Text text="{dashboard>childId}" wrapping="false" tooltip="{dashboard>childId}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="12rem"><Label text="{dashboard>/hierarchyOwnerLabel}" /><t:template><Text text="{path: 'dashboard>manager', formatter: '.formatter.empty'}" wrapping="false" tooltip="{dashboard>manager}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="14rem" hAlign="End"><Label text="장부 순잔액" /><t:template><Text text="{path: 'dashboard>amount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText" /></t:template></t:Column>
                                    </t:columns>
                                </t:TreeTable>
                            </VBox>

                            <VBox class="ze4Card ze4ChartCard ze4TrendPanel">
                                <HBox class="ze4CardHeader" alignItems="Center">
                                    <Title text="{dashboard>/chartTitle}" level="H3" />
                                    <ToolbarSpacer />
                                    <Text class="ze4CardUnit" text="단위: KRW" />
                                </HBox>
                                <viz:VizFrame id="trendChart" height="20rem" width="100%" vizType="line" uiConfig="{applicationSet:'fiori'}" visible="{dashboard>/hasTrendData}" selectData=".onTrendChartSelectData">
                                    <viz:dataset>
                                        <vizData:FlattenedDataset data="{dashboard>/monthlyTrend}">
                                            <vizData:dimensions>
                                                <vizData:DimensionDefinition name="조회 월" value="{dashboard>monthText}" />
                                            </vizData:dimensions>
                                            <vizData:measures>
                                                <vizData:MeasureDefinition name="실적" value="{dashboard>actualAmount}" />
                                                <vizData:MeasureDefinition name="예산" value="{dashboard>budgetAmount}" />
                                            </vizData:measures>
                                        </vizData:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="실적,예산" />
                                        <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="조회 월" />
                                    </viz:feeds>
                                    <viz:dependents>
                                        <viz:Popover id="trendChartPopover" />
                                    </viz:dependents>
                                </viz:VizFrame>
                                <VBox class="ze4ChartEmptyState" visible="{= !${dashboard>/hasTrendData} }">
                                    <Text text="월별 비용 데이터가 없습니다." />
                                </VBox>
                                <VBox class="ze4ChartSelectionInfo" visible="{dashboard>/hasSelectedMonthSummary}">
                                    <Title text="선택 월 요약" level="H4" />
                                    <FlexBox class="ze4SelectionFacts" wrap="Wrap">
                                        <ObjectAttribute title="선택 월" text="{dashboard>/selectedMonthSummary/monthText}" />
                                        <ObjectAttribute title="실적 비용" text="{path: 'dashboard>/selectedMonthSummary/actualAmount', formatter: '.formatter.amountWithCurrency'}" />
                                        <ObjectAttribute title="예산" text="{path: 'dashboard>/selectedMonthSummary/budgetAmount', formatter: '.formatter.amountWithCurrency'}" />
                                        <ObjectAttribute title="전월대비" text="{path: 'dashboard>/selectedMonthSummary/momAmount', formatter: '.formatter.amountWithCurrency'}" />
                                        <ObjectAttribute title="전표 건수" text="{= ${dashboard>/selectedMonthSummary/documentCount} + '건' }" />
                                    </FlexBox>
                                </VBox>
                            </VBox>

                            <VBox class="ze4Card ze4ChartCard ze4FunctionalAreaSharePanel">
                                <HBox class="ze4CardHeader" alignItems="Center">
                                    <Title text="기능영역별 비용 비율" level="H3" />
                                    <ToolbarSpacer />
                                    <Text class="ze4CardUnit" text="단위: KRW" />
                                </HBox>
                                <viz:VizFrame id="functionalAreaShareChart" class="ze4FunctionalAreaShareChart" height="20rem" width="100%" vizType="donut" uiConfig="{applicationSet:'fiori'}" visible="{dashboard>/hasFunctionalAreaShareData}" selectData=".onFunctionalAreaChartSelectData">
                                    <viz:dataset>
                                        <vizData:FlattenedDataset data="{dashboard>/functionalAreaShareRows}">
                                            <vizData:dimensions>
                                                <vizData:DimensionDefinition name="기능영역" value="{dashboard>displayText}" />
                                            </vizData:dimensions>
                                            <vizData:measures>
                                                <vizData:MeasureDefinition name="구성비 기준금액" value="{dashboard>chartAmount}" />
                                            </vizData:measures>
                                        </vizData:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <vizFeeds:FeedItem uid="size" type="Measure" values="구성비 기준금액" />
                                        <vizFeeds:FeedItem uid="color" type="Dimension" values="기능영역" />
                                    </viz:feeds>
                                    <viz:dependents>
                                        <viz:Popover id="functionalAreaShareChartPopover" />
                                    </viz:dependents>
                                </viz:VizFrame>
                                <VBox class="ze4ChartEmptyState" visible="{= !${dashboard>/hasFunctionalAreaShareData} }">
                                    <Text text="기능영역 데이터가 없습니다." />
                                </VBox>
                            </VBox>
                        </HBox>

                        <HBox class="ze4DashboardLowerRow">
                            <VBox class="ze4Card ze4ChartCard ze4CompositionPanel">
                                <HBox class="ze4CardHeader" alignItems="Center">
                                    <Title text="{dashboard>/compositionTitle}" level="H3" />
                                    <ToolbarSpacer />
                                    <Text class="ze4CardUnit" text="단위: KRW" />
                                </HBox>
                                <viz:VizFrame id="compositionChart" height="22rem" width="100%" vizType="donut" uiConfig="{applicationSet:'fiori'}" visible="{dashboard>/hasCompositionData}" selectData=".onCompositionChartSelectData">
                                    <viz:dataset>
                                        <vizData:FlattenedDataset data="{dashboard>/accountComposition}">
                                            <vizData:dimensions>
                                                <vizData:DimensionDefinition name="계정명" value="{dashboard>accountLabel}" />
                                            </vizData:dimensions>
                                            <vizData:measures>
                                                <vizData:MeasureDefinition name="금액" value="{dashboard>chartAmount}" />
                                            </vizData:measures>
                                        </vizData:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <vizFeeds:FeedItem uid="size" type="Measure" values="금액" />
                                        <vizFeeds:FeedItem uid="color" type="Dimension" values="계정명" />
                                    </viz:feeds>
                                    <viz:dependents>
                                        <viz:Popover id="compositionChartPopover" />
                                    </viz:dependents>
                                </viz:VizFrame>
                                <VBox class="ze4ChartEmptyState" visible="{= !${dashboard>/hasCompositionData} }">
                                    <Text text="비용계정 구성 데이터가 없습니다." />
                                </VBox>
                                <VBox class="ze4ChartSelectionInfo" visible="{dashboard>/hasSelectedAccountSummary}">
                                    <HBox alignItems="Center">
                                        <Title text="선택 계정 요약" level="H4" />
                                        <ToolbarSpacer />
                                        <Button text="전표 상세" type="Transparent" icon="sap-icon://navigation-right-arrow" press=".onGoSelectedAccountDocuments" enabled="{= ${dashboard>/selectedAccountSummary/saknr} !== 'ETC' }" />
                                    </HBox>
                                    <FlexBox class="ze4SelectionFacts" wrap="Wrap">
                                        <ObjectAttribute title="선택 계정" text="{dashboard>/selectedAccountSummary/accountLabel}" />
                                        <ObjectAttribute title="금액" text="{path: 'dashboard>/selectedAccountSummary/amount', formatter: '.formatter.amountWithCurrency'}" />
                                        <ObjectAttribute title="비율" text="{path: 'dashboard>/selectedAccountSummary/ratio', formatter: '.formatter.rate'}" />
                                        <ObjectAttribute title="전표 건수" text="{= ${dashboard>/selectedAccountSummary/documentCount} + '건' }" />
                                    </FlexBox>
                                </VBox>
                            </VBox>

                            <VBox class="ze4Card ze4TableCard ze4DashboardTablePanel">
                                <HBox class="ze4CardHeader" alignItems="Center">
                                    <Title text="{dashboard>/tableTitle}" level="H3" />
                                    <ToolbarSpacer />
                                    <Text class="ze4CardUnit" text="단위: KRW" />
                                </HBox>
                                <t:Table
                                    id="costCenterTable"
                                    rows="{dashboard>/costCenterRows}"
                                    selectionMode="Single"
                                    selectionBehavior="Row"
                                    rowSelectionChange=".onCostCenterRowSelection"
                                    visibleRowCount="10"
                                    width="100%"
                                    fixedColumnCount="2"
                                    enableColumnReordering="true"
                                    class="ze4GridTable ze4Table">
                                    <t:rowSettingsTemplate>
                                        <t:RowSettings highlight="{dashboard>functionalAreaHighlightState}" />
                                    </t:rowSettingsTemplate>
                                    <t:columns>
                                        <t:Column width="4.5rem"><Label text="순위" /><t:template><Text text="{dashboard>rank}" wrapping="false" class="ze4DashboardNumberText ze4DashboardRankText" /></t:template></t:Column>
                                        <t:Column width="8rem"><Label text="{dashboard>/tableKeyLabel}" /><t:template><Text text="{dashboard>kostl}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="14rem"><Label text="{dashboard>/tableNameLabel}" /><t:template><Text text="{dashboard>kostlTxt}" wrapping="false" tooltip="{dashboard>costCenterTooltip}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="10rem"><Label text="{dashboard>/tableOwnerLabel}" /><t:template><Text text="{dashboard>manager}" wrapping="false" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="8rem"><Label text="기능영역" /><t:template><Text text="{path: 'dashboard>fkber', formatter: '.formatter.empty'}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="13rem"><Label text="기능영역명" /><t:template><Text text="{path: 'dashboard>fkberTxt', formatter: '.formatter.empty'}" wrapping="false" tooltip="{dashboard>fkberTxt}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="9rem"><Label text="손익센터" /><t:template><Text text="{path: 'dashboard>prctr', formatter: '.formatter.empty'}" wrapping="false" /></t:template></t:Column>
                                        <t:Column width="13rem"><Label text="손익센터명" /><t:template><Text text="{path: 'dashboard>prctrTxt', formatter: '.formatter.empty'}" wrapping="false" tooltip="{dashboard>prctrTxt}" class="ze4NoWrapText" /></t:template></t:Column>
                                        <t:Column width="11rem" hAlign="End"><Label text="장부 순잔액" /><t:template><Text text="{path: 'dashboard>actualAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText ze4DashboardNumberText" /></t:template></t:Column>
                                        <t:Column width="12rem" hAlign="End"><Label text="이번달 장부 순잔액" /><t:template><Text text="{path: 'dashboard>currentAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText ze4DashboardNumberText" /></t:template></t:Column>
                                        <t:Column width="11rem" hAlign="End"><Label text="전월비용" /><t:template><Text text="{path: 'dashboard>previousAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText ze4DashboardNumberText" /></t:template></t:Column>
                                        <t:Column width="11rem" hAlign="End"><Label text="예산" /><t:template><Text text="{path: 'dashboard>budgetAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText ze4DashboardNumberText" /></t:template></t:Column>
                                        <t:Column width="11rem" hAlign="End"><Label text="차이" /><t:template><ObjectStatus class="ze4DashboardNumberStatus" text="{path: 'dashboard>varianceAmount', formatter: '.formatter.amount'}" state="{dashboard>varianceState}" /></t:template></t:Column>
                                        <t:Column width="8rem" hAlign="End"><Label text="예산대비" /><t:template><ObjectStatus class="ze4DashboardNumberStatus" text="{path: 'dashboard>varianceRate', formatter: '.formatter.rate'}" state="{dashboard>varianceState}" /></t:template></t:Column>
                                        <t:Column width="10rem" hAlign="End"><Label text="전월대비" /><t:template><ObjectStatus class="ze4DashboardNumberStatus" text="{path: 'dashboard>momAmount', formatter: '.formatter.amount'}" state="{dashboard>momState}" /></t:template></t:Column>
                                        <t:Column width="8rem" hAlign="End"><Label text="전표건수" /><t:template><Text text="{path: 'dashboard>documentCount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4DashboardNumberText" /></t:template></t:Column>
                                        <t:Column width="7rem"><Label text="상태" /><t:template><ObjectStatus text="{dashboard>statusText}" state="{dashboard>statusState}" /></t:template></t:Column>
                                    </t:columns>
                                </t:Table>
                            </VBox>
                        </HBox>
                    </VBox>
                </content>
    </Page>
</mvc:View>
