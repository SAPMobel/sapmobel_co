<mvc:View
    controllerName="ZE4_CC_COST.controller.AllocationAnalysis"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds"
    xmlns:vizData="sap.viz.ui5.data">
    <Page
        class="ze4DynamicPage sapUiSizeCompact"
        showHeader="false"
        enableScrolling="true"
        busy="{allocation>/busy}"
        busyIndicatorDelay="0">
        <content>
            <VBox class="ze4PageContent ze4AllocationContent">
                <HBox class="ze4PageTitleBar" alignItems="Center" wrap="Wrap">
                    <Title text="{allocation>/pageTitle}" level="H1" titleStyle="H1" class="ze4PageHeroTitle" />
                    <ToolbarSpacer />
                    <HBox class="ze4PageActions" alignItems="Center">
                        <Button text="대시보드" icon="sap-icon://home" type="Transparent" press=".onGoDashboard" />
                        <Button text="배부 분석" icon="sap-icon://business-objects-experience" type="Transparent" press=".onGoAllocationAnalysis" />
                        <Button text="조직도 탐색" icon="sap-icon://org-chart" type="Transparent" press=".onGoOrgExplorer" />
                        <Button text="흐름 맵 보기" icon="sap-icon://process" type="Emphasized" press=".onOpenAllocationMap" />
                    </HBox>
                </HBox>

                <VBox class="ze4FilterBar">
                    <HBox class="ze4FilterHeader" alignItems="Center">
                        <Title text="조회 조건" level="H3" />
                        <ToolbarSpacer />
                        <Button text="{allocation>/filterToggleText}" type="Transparent" press=".onToggleFilter" />
                    </HBox>
                    <FlexBox class="ze4FilterFields" visible="{allocation>/filterVisible}" wrap="Wrap" alignItems="End">
                        <VBox class="ze4FilterField">
                            <Label text="회사코드" />
                            <Input value="{allocation>/filters/bukrs}" editable="false" enabled="false" class="ze4FixedInput" width="9rem" />
                        </VBox>
                        <VBox class="ze4FilterField">
                            <Label text="회계연도" required="true" />
                            <Input
                                value="{allocation>/filters/gjahr}"
                                valueState="{allocation>/filterStates/gjahrState}"
                                valueStateText="{allocation>/filterStates/gjahrStateText}"
                                maxLength="4"
                                width="8rem" />
                        </VBox>
                        <VBox class="ze4FilterField">
                            <Label text="기간" required="true" />
                            <Select
                                selectedKey="{allocation>/filters/period}"
                                valueState="{allocation>/filterStates/periodState}"
                                valueStateText="{allocation>/filterStates/periodStateText}"
                                items="{allocation>/periodOptions}"
                                width="8rem">
                                <core:Item key="{allocation>key}" text="{allocation>text}" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField ze4FilterFieldWide">
                            <Label text="배부사이클" />
                            <Select selectedKey="{allocation>/filters/cycle}" items="{allocation>/cycleOptions}" width="17rem">
                                <core:Item key="{allocation>key}" text="{allocation>text}" />
                            </Select>
                        </VBox>
                        <VBox class="ze4FilterField">
                            <Label text="송신부서" />
                            <Input value="{allocation>/filters/senderKostl}" width="10rem" />
                        </VBox>
                        <VBox class="ze4FilterField">
                            <Label text="수신부서" />
                            <Input value="{allocation>/filters/receiverKostl}" width="10rem" />
                        </VBox>
                        <VBox class="ze4FilterField ze4FilterFieldWide">
                            <Label text="배부기준/SKF" />
                            <Select selectedKey="{allocation>/filters/skfId}" items="{allocation>/skfOptions}" width="17rem">
                                <core:Item key="{allocation>key}" text="{allocation>text}" />
                            </Select>
                        </VBox>
                        <Button class="ze4SearchButton" text="검색" icon="sap-icon://search" type="Emphasized" press=".onSearch" />
                        <Button text="초기화" type="Transparent" press=".onResetFilters" />
                    </FlexBox>
                    <MessageStrip
                        class="ze4MessageStrip"
                        visible="{allocation>/warningVisible}"
                        text="{allocation>/warningText}"
                        type="Warning"
                        showIcon="true" />
                </VBox>

                <FlexBox class="ze4KpiGrid" wrap="Wrap" items="{allocation>/kpis}">
                    <VBox class="ze4KpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="{allocation>icon}" class="ze4KpiIcon" color="{allocation>iconColor}" backgroundColor="{allocation>iconBackground}" />
                            <VBox class="ze4KpiText">
                                <Text class="ze4KpiTitle" text="{allocation>title}" />
                                <ObjectStatus class="ze4KpiValueStatus" text="{allocation>valueText}" state="{allocation>valueState}" tooltip="{allocation>valueText}" />
                            </VBox>
                        </HBox>
                        <ObjectStatus class="ze4KpiSub" text="{allocation>subText}" state="{allocation>state}" />
                    </VBox>
                </FlexBox>

                <VBox class="ze4Card ze4ChartCard ze4AllocationTrendCard">
                    <HBox class="ze4CardHeader" alignItems="Center">
                        <Title text="월별 배부 추이" level="H3" />
                        <ToolbarSpacer />
                        <Text class="ze4CardUnit" text="단위: KRW" />
                    </HBox>
                    <viz:VizFrame id="allocationTrendChart" height="20rem" width="100%" vizType="dual_combination" uiConfig="{applicationSet:'fiori'}" visible="{allocation>/hasTrendData}">
                        <viz:dataset>
                            <vizData:FlattenedDataset data="{allocation>/monthlyTrend}">
                                <vizData:dimensions>
                                    <vizData:DimensionDefinition name="배부 월" value="{allocation>monthText}" />
                                </vizData:dimensions>
                                <vizData:measures>
                                    <vizData:MeasureDefinition name="배부금액" value="{allocation>amount}" />
                                    <vizData:MeasureDefinition name="배부건수" value="{allocation>documentCount}" />
                                </vizData:measures>
                            </vizData:FlattenedDataset>
                        </viz:dataset>
                        <viz:feeds>
                            <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="배부금액" />
                            <vizFeeds:FeedItem uid="valueAxis2" type="Measure" values="배부건수" />
                            <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="배부 월" />
                        </viz:feeds>
                        <viz:dependents>
                            <viz:Popover id="allocationTrendChartPopover" />
                        </viz:dependents>
                    </viz:VizFrame>
                    <VBox class="ze4ChartEmptyState" visible="{= !${allocation>/hasTrendData} }">
                        <Text text="배부 전표 데이터가 없습니다." />
                    </VBox>
                </VBox>

                <HBox class="ze4AllocationSummaryGrid">
                    <VBox class="ze4Card ze4TableCard">
                        <HBox class="ze4CardHeader" alignItems="Center">
                            <Title text="상위 송신부서 TOP 5" level="H3" />
                            <ToolbarSpacer />
                            <Text class="ze4CardUnit" text="단위: KRW" />
                        </HBox>
                        <t:Table
                            rows="{allocation>/topSenders}"
                            selectionMode="None"
                            visibleRowCount="5"
                            width="100%"
                            noData="배부 전표 데이터가 없습니다."
                            class="ze4GridTable ze4Table">
                            <t:columns>
                                <t:Column width="13rem"><Label text="송신부서" /><t:template><Text text="{allocation>text}" wrapping="false" tooltip="{allocation>tooltip}" class="ze4NoWrapText" /></t:template></t:Column>
                                <t:Column width="11rem" hAlign="End"><Label text="배부금액" /><t:template><Text text="{path: 'allocation>amount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText" /></t:template></t:Column>
                                <t:Column width="7rem" hAlign="End"><Label text="전표건수" /><t:template><Text text="{allocation>documentCountText}" textAlign="End" wrapping="false" /></t:template></t:Column>
                            </t:columns>
                        </t:Table>
                    </VBox>

                    <VBox class="ze4Card ze4TableCard">
                        <HBox class="ze4CardHeader" alignItems="Center">
                            <Title text="상위 수신부서 TOP 5" level="H3" />
                            <ToolbarSpacer />
                            <Text class="ze4CardUnit" text="단위: KRW" />
                        </HBox>
                        <t:Table
                            rows="{allocation>/topReceivers}"
                            selectionMode="None"
                            visibleRowCount="5"
                            width="100%"
                            noData="배부 전표 데이터가 없습니다."
                            class="ze4GridTable ze4Table">
                            <t:columns>
                                <t:Column width="13rem"><Label text="수신부서" /><t:template><Text text="{allocation>text}" wrapping="false" tooltip="{allocation>tooltip}" class="ze4NoWrapText" /></t:template></t:Column>
                                <t:Column width="11rem" hAlign="End"><Label text="배부금액" /><t:template><Text text="{path: 'allocation>amount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText" /></t:template></t:Column>
                                <t:Column width="7rem" hAlign="End"><Label text="전표건수" /><t:template><Text text="{allocation>documentCountText}" textAlign="End" wrapping="false" /></t:template></t:Column>
                            </t:columns>
                        </t:Table>
                    </VBox>
                </HBox>

                <VBox class="ze4Card ze4TableCard ze4AllocationDetailCard">
                    <HBox class="ze4CardHeader" alignItems="Center">
                        <Title text="배부 결과 상세 요약" level="H3" />
                        <ToolbarSpacer />
                        <Button text="흐름 맵 보기" icon="sap-icon://process" type="Emphasized" press=".onOpenAllocationMap" />
                    </HBox>
                    <t:Table
                        id="allocationDetailTable"
                        rows="{allocation>/detailRows}"
                        selectionMode="None"
                        visibleRowCount="10"
                        width="100%"
                        fixedColumnCount="2"
                        enableColumnReordering="true"
                        noData="배부 전표 데이터가 없습니다."
                        class="ze4GridTable ze4Table ze4AllocationDetailTable">
                        <t:columns>
                            <t:Column width="13rem"><Label text="송신부서" /><t:template><Text text="{allocation>senderText}" wrapping="false" tooltip="{allocation>senderTooltip}" class="ze4NoWrapText" /></t:template></t:Column>
                            <t:Column width="13rem"><Label text="수신부서" /><t:template><Text text="{allocation>receiverText}" wrapping="false" tooltip="{allocation>receiverTooltip}" class="ze4NoWrapText" /></t:template></t:Column>
                            <t:Column width="13rem"><Label text="수신 프로핏센터" /><t:template><Text text="{allocation>receiverPrctrText}" wrapping="false" tooltip="{allocation>receiverPrctrText}" class="ze4NoWrapText" /></t:template></t:Column>
                            <t:Column width="13rem"><Label text="배부사이클" /><t:template><Text text="{allocation>cycleText}" wrapping="false" tooltip="{allocation>cycleText}" class="ze4NoWrapText" /></t:template></t:Column>
                            <t:Column width="13rem"><Label text="배부규칙/세그먼트" /><t:template><Text text="{allocation>segmentText}" wrapping="false" tooltip="{allocation>segmentText}" class="ze4NoWrapText" /></t:template></t:Column>
                            <t:Column width="13rem"><Label text="배부기준" /><t:template><Text text="{allocation>skfText}" wrapping="false" tooltip="{allocation>skfText}" class="ze4NoWrapText" /></t:template></t:Column>
                            <t:Column width="10rem" hAlign="End"><Label text="배부기준값" /><t:template><Text text="{allocation>basisValueText}" textAlign="End" wrapping="false" class="ze4AmountText" /></t:template></t:Column>
                            <t:Column width="11rem" hAlign="End"><Label text="배부금액" /><t:template><Text text="{path: 'allocation>allocAmount', formatter: '.formatter.amount'}" textAlign="End" wrapping="false" class="ze4AmountText" /></t:template></t:Column>
                            <t:Column width="7rem" hAlign="End"><Label text="비율" /><t:template><Text text="{allocation>basisRatioText}" textAlign="End" wrapping="false" /></t:template></t:Column>
                            <t:Column width="10rem"><Label text="전표번호" /><t:template><Text text="{allocation>belnr}" wrapping="false" /></t:template></t:Column>
                            <t:Column width="8rem"><Label text="전기일자" /><t:template><Text text="{path: 'allocation>budat', formatter: '.formatter.date'}" wrapping="false" /></t:template></t:Column>
                        </t:columns>
                    </t:Table>
                </VBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
