<mvc:View controllerName="ze4.co.s.cost.ze4coscost.controller.StandardCostDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls">
    <Page id="detailPage" 
        title="{i18n>detailTitle}" 
        showHeader="false"
        showNavButton="false"
        navButtonPress=".onNavBack">
        <content>
            <VBox class="sapUiContentPadding standardCostPage detailPageContent" width="100%">
                <HBox class="breadcrumbLine" alignItems="Center">
                    <Link text="{i18n>breadcrumbList}" press=".onNavBack"/>
                    <core:Icon src="sap-icon://slim-arrow-right" class="breadcrumbIcon"/>
                    <Text text="{detail>/matnr}"/>
                </HBox>

                <Title text="{i18n>detailTitle}" level="H1" titleStyle="H1" class="pageHeroTitle"/>

                <Panel class="appCard detailHeaderCard" width="100%" backgroundDesign="Solid">
                    <content>
                        <FlexBox wrap="Wrap" alignItems="Center" justifyContent="SpaceBetween" class="detailHeaderGrid">
                            <VBox class="detailInfoBlock">
                                <Label text="{i18n>lblMaterialNumber}"/>
                                <ObjectIdentifier title="{detail>/matnr}" class="detailKeyText"/>
                            </VBox>
                            <VBox class="detailInfoBlock wide">
                                <Label text="{i18n>lblMaterialName}"/>
                                <Title text="{detail>/maktx}" level="H2"/>
                            </VBox>
                            <VBox class="detailInfoBlock">
                                <Label text="{i18n>lblMaterialType}"/>
                                <Text text="{detail>/mtbez}" class="detailValueText"/>
                                <Text text="{detail>/mtart}" class="detailSubText"/>
                            </VBox>
                            <VBox class="detailInfoBlock">
                                <Label text="{i18n>lblMaterialGroup}"/>
                                <Text text="{detail>/wgbez}" class="detailValueText"/>
                                <Text text="{detail>/matkl}" class="detailSubText"/>
                            </VBox>
                            <VBox class="detailInfoBlock">
                                <Label text="{i18n>lblYearMonth}"/>
                                <Text text="{= ${detail>/gjahr} + ' / ' + ${detail>/monat} }" class="detailValueText"/>
                            </VBox>
                            <VBox class="detailInfoBlock">
                                <Label text="{i18n>lblCostCenter}"/>
                                <Link text="{detail>/kostl}"/>
                                <Text text="{detail>/ktext}" class="detailSubText"/>
                            </VBox>
                            <VBox class="totalCostBox">
                                <Label text="{i18n>lblTotalCost}"/>
                                <ObjectNumber number="{path: 'detail>/total_cost', formatter: '.formatAmount'}" unit="{detail>/waers}" emphasized="true"/>
                            </VBox>
                        </FlexBox>
                        <HBox class="detailActionRow">
                            <Button text="{i18n>btnStockLink}" icon="sap-icon://chain-link" enabled="false"/>
                            <Button text="{i18n>btnReservationExpanded}" icon="sap-icon://database" enabled="false"/>
                            <Button text="{i18n>expandBadge}" icon="sap-icon://syntax" enabled="false"/>
                        </HBox>
                    </content>
                </Panel>

                <Panel class="appCard detailTabsCard" width="100%" backgroundDesign="Solid">
                    <headerToolbar>
                        <OverflowToolbar>
                            <ToolbarSpacer/>
                            <Button icon="sap-icon://full-screen" type="Transparent" tooltip="{i18n>btnFullScreen}"/>
                            <Button icon="sap-icon://action-settings" type="Transparent" tooltip="{i18n>btnSettings}"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <IconTabBar id="detailTabs" expandable="false" class="detailTabs">
                            <IconTabFilter text="{i18n>tabCostBreakdown}" icon="sap-icon://detail-view">
                                <FlexBox wrap="Wrap" class="breakdownGrid">
                                    <Panel class="breakdownPanel" backgroundDesign="Solid">
                                        <headerToolbar>
                                            <OverflowToolbar>
                                                <Title text="{i18n>costBreakdownTitle}" level="H2"/>
                                                <ToolbarSpacer/>
                                                <Button icon="sap-icon://full-screen" type="Transparent" tooltip="{i18n>btnFullScreen}"/>
                                                <Button icon="sap-icon://action-settings" type="Transparent" tooltip="{i18n>btnSettings}"/>
                                            </OverflowToolbar>
                                        </headerToolbar>
                                        <content>
                                            <Table id="costComponentTable" 
                                                items="{detail>/to_Item/results}"
                                                mode="None">
                                                <columns>
                                                    <Column>
                                                        <Label text="{i18n>colCostComp}"/>
                                                    </Column>
                                                    <Column hAlign="End">
                                                        <Label text="{i18n>colAmount}"/>
                                                    </Column>
                                                    <Column hAlign="End">
                                                        <Label text="{i18n>colPercent}"/>
                                                    </Column>
                                                    <Column hAlign="Center">
                                                        <Label text="{i18n>colCurrency}"/>
                                                    </Column>
                                                </columns>
                                                <items>
                                                    <ColumnListItem>
                                                        <Text text="{detail>cost_comp_text}"/>
                                                        <ObjectNumber class="amountText" number="{path: 'detail>amount', formatter: '.formatAmount'}" unit="{detail>waers}" emphasized="true"/>
                                                        <ObjectNumber number="{path: 'detail>percent', formatter: '.formatPercent'}" unit="%" emphasized="false"/>
                                                        <Text text="{detail>waers}"/>
                                                    </ColumnListItem>
                                                </items>
                                            </Table>
                                        </content>
                                    </Panel>

                                    <Panel class="breakdownPanel" backgroundDesign="Solid">
                                        <headerToolbar>
                                            <OverflowToolbar>
                                                <Title text="{i18n>costChartTitle}" level="H2"/>
                                                <ToolbarSpacer/>
                                                <Button icon="sap-icon://full-screen" type="Transparent" tooltip="{i18n>btnFullScreen}"/>
                                            </OverflowToolbar>
                                        </headerToolbar>
                                        <content>
                                            <viz:VizFrame id="costDonutChart" 
                                                vizType="donut"
                                                width="100%"
                                                height="22rem">
                                            </viz:VizFrame>
                                        </content>
                                    </Panel>
                                </FlexBox>

                                <Panel class="reservationSummaryCard" backgroundDesign="Solid">
                                    <content>
                                        <HBox alignItems="Center" justifyContent="SpaceAround" class="reservationSummary">
                                            <Title text="{i18n>reservationSummaryTitle}" level="H3"/>
                                            <ObjectStatus icon="sap-icon://documents" title="{i18n>summaryReservationCount}" text="{path: 'detail>/reservationSummary/count', formatter: '.formatQuantity'}"/>
                                            <ObjectStatus icon="sap-icon://shipping-status" title="{i18n>summaryOpenQuantity}" text="{path: 'detail>/reservationSummary/openQuantity', formatter: '.formatQuantity'}" state="Information"/>
                                            <ObjectStatus icon="sap-icon://flag" title="{i18n>summaryDeletedCount}" text="{path: 'detail>/reservationSummary/deletedCount', formatter: '.formatQuantity'}" state="Warning"/>
                                        </HBox>
                                    </content>
                                </Panel>
                            </IconTabFilter>

                            <IconTabFilter text="{i18n>tabReservationTracking}" icon="sap-icon://table-view">
                                <Table id="reservationTable" 
                                    items="{detail>/to_Reservation/results}"
                                    mode="None"
                                    updateFinished=".onReservationUpdateFinished"
                                    class="reservationTable">
                                    <columns>
                                        <Column>
                                            <Label text="{i18n>colBanfn}"/>
                                        </Column>
                                        <Column>
                                            <Label text="{i18n>colRsnum}"/>
                                        </Column>
                                        <Column hAlign="End">
                                            <Label text="{i18n>colMenge}"/>
                                        </Column>
                                        <Column hAlign="End">
                                            <Label text="{i18n>colResme}"/>
                                        </Column>
                                        <Column hAlign="Center">
                                            <Label text="{i18n>colUnit}"/>
                                        </Column>
                                        <Column hAlign="Center">
                                            <Label text="{i18n>colDeleteFlag}"/>
                                        </Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem>
                                            <Text text="{detail>banfn}"/>
                                            <Text text="{detail>rsnum}"/>
                                            <ObjectNumber number="{path: 'detail>menge', formatter: '.formatQuantity'}" unit="{detail>meins}" emphasized="false"/>
                                            <ObjectNumber number="{path: 'detail>resme', formatter: '.formatQuantity'}" unit="{detail>meins}" emphasized="false"/>
                                            <Text text="{detail>meins}"/>
                                            <ObjectStatus text="{path: 'detail>loekz', formatter: '.formatDeleteFlag'}" state="{path: 'detail>loekz', formatter: '.formatDeleteState'}"/>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </IconTabFilter>
                        </IconTabBar>
                    </content>
                </Panel>
            </VBox>
        </content>
    </Page>
</mvc:View>
