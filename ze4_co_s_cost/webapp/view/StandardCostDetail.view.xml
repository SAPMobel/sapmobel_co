<mvc:View controllerName="ze4.co.s.cost.ze4coscost.controller.StandardCostDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls">
    <Page id="detailPage" 
        title="{i18n>detailTitle}" 
        showHeader="false"
        showNavButton="false"
        navButtonPress=".onNavBack">
        <content>
            <VBox class="sapUiContentPadding standardCostPage detailPageContent" width="100%">
                <HBox class="breadcrumbLine" alignItems="Center">
                    <Link text="{i18n>breadcrumbList}" press=".onNavBack"/>
                    <core:Icon src="sap-icon://slim-arrow-right" class="breadcrumbIcon"/>
                    <Text text="{detail>/matnr}"/>
                </HBox>

                <Title text="{i18n>detailTitle}" level="H1" titleStyle="H1" class="pageHeroTitle"/>

                <Panel class="appCard detailHeaderCard" width="100%" backgroundDesign="Solid">
                    <content>
                        <FlexBox wrap="Wrap" alignItems="Center" justifyContent="SpaceBetween" class="detailHeaderGrid">
                            <VBox class="detailInfoBlock">
                                <Label text="{i18n>lblMaterialNumber}"/>
                                <ObjectIdentifier title="{detail>/matnr}" class="detailKeyText"/>
                            </VBox>
                            <VBox class="detailInfoBlock wide">
                                <Label text="{i18n>lblMaterialName}"/>
                                <Title text="{detail>/maktx}" level="H2"/>
                            </VBox>
                            <VBox class="detailInfoBlock">
                                <Label text="{i18n>lblOption}"/>
                                <Text text="{detail>/mtopt_t}" class="detailValueText"/>
                                <Text text="{detail>/mtopt}" class="detailSubText"/>
                            </VBox>
                            <VBox class="detailInfoBlock">
                                <Label text="{i18n>lblMaterialType}"/>
                                <Text text="{detail>/mtbez}" class="detailValueText"/>
                                <Text text="{detail>/mtart}" class="detailSubText"/>
                            </VBox>
                            <VBox class="detailInfoBlock">
                                <Label text="{i18n>lblMaterialGroup}"/>
                                <Text text="{detail>/wgbez}" class="detailValueText"/>
                                <Text text="{detail>/matkl}" class="detailSubText"/>
                            </VBox>
                            <VBox class="detailInfoBlock">
                                <Label text="{i18n>lblYearMonth}"/>
                                <Text text="{= ${detail>/gjahr} + ' / ' + ${detail>/monat} }" class="detailValueText"/>
                            </VBox>
                            <VBox class="totalCostBox">
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://money-bills" class="totalCostIcon"/>
                                    <VBox>
                                        <Label text="{i18n>lblTotalCost}"/>
                                        <ObjectNumber number="{parts: [{path: 'detail>/total_cost'}, {path: 'detail>/waers'}], formatter: '.formatAmount'}" unit="{detail>/waers}" emphasized="true" state="Information"/>
                                    </VBox>
                                </HBox>
                            </VBox>
                        </FlexBox>
                        <HBox class="detailActionRow">
                            <ObjectStatus text="{i18n>stockLinkedStatus}" icon="sap-icon://chain-link" state="Success" class="detailStatusBadge"/>
                            <ObjectStatus text="{i18n>reservationExpandedStatus}" icon="sap-icon://database" state="Success" class="detailStatusBadge"/>
                        </HBox>
                    </content>
                </Panel>

                <Panel class="appCard detailTabsCard" width="100%" backgroundDesign="Solid">
                    <headerToolbar>
                        <OverflowToolbar>
                            <ToolbarSpacer/>
                            <Button text="{i18n>btnExcelExport}" icon="sap-icon://excel-attachment" type="Transparent" press=".onExportExcel"/>
                            <Button text="{i18n>btnPdfExport}" icon="sap-icon://print" type="Transparent" press=".onExportPdf"/>
                            <Button icon="sap-icon://full-screen" type="Transparent" tooltip="{i18n>btnFullScreen}"/>
                            <Button icon="sap-icon://action-settings" type="Transparent" tooltip="{i18n>btnSettings}"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <IconTabBar id="detailTabs" expandable="false" class="detailTabs" select=".onDetailTabSelect">
                            <items>
                                <IconTabFilter key="breakdown" text="{i18n>tabCostBreakdown}" icon="sap-icon://detail-view" tooltip="{i18n>tabCostBreakdownTooltip}">
                                    <content>
                                        <VBox id="breakdownGrid" renderType="Bare" class="breakdownGrid" width="100%">
                                            <Panel class="breakdownPanel costComponentPanel" backgroundDesign="Solid">
                                                <headerToolbar>
                                                    <OverflowToolbar>
                                                        <Title text="{i18n>costBreakdownTitle}" level="H2"/>
                                                        <ToolbarSpacer/>
                                                        <Button icon="sap-icon://full-screen" type="Transparent" tooltip="{i18n>btnFullScreen}"/>
                                                        <Button icon="sap-icon://action-settings" type="Transparent" tooltip="{i18n>btnSettings}"/>
                                                    </OverflowToolbar>
                                                </headerToolbar>
                                                <content>
                                                    <Table id="costComponentTable"
                                                        items="{detail>/to_Item/results}"
                                                        mode="None">
                                                        <columns>
                                                            <Column>
                                                                <Label text="{i18n>colCostComp}"/>
                                                            </Column>
                                                            <Column hAlign="End">
                                                                <Label text="{i18n>colAmount}"/>
                                                            </Column>
                                                            <Column hAlign="End">
                                                                <Label text="{i18n>colPercent}"/>
                                                            </Column>
                                                            <Column hAlign="Center">
                                                                <Label text="{i18n>colCurrency}"/>
                                                            </Column>
                                                        </columns>
                                                        <items>
                                                            <ColumnListItem>
                                                                <Text text="{detail>cost_comp_text}"/>
                                                                <ObjectNumber class="amountText" number="{parts: [{path: 'detail>amount'}, {path: 'detail>waers'}], formatter: '.formatAmount'}" emphasized="true"/>
                                                                <ObjectNumber number="{path: 'detail>percent', formatter: '.formatPercent'}" unit="%" emphasized="false"/>
                                                                <Text text="{detail>waers}"/>
                                                            </ColumnListItem>
                                                        </items>
                                                    </Table>
                                                </content>
                                            </Panel>

                                            <Panel class="breakdownPanel costChartPanel" backgroundDesign="Solid">
                                                <headerToolbar>
                                                    <OverflowToolbar>
                                                        <Title text="{= ${detail>/isBomChart} ? ${i18n>materialChartTitle} : ${i18n>costChartTitle} }" level="H2"/>
                                                        <ToolbarSpacer/>
                                                        <Button icon="sap-icon://undo" type="Transparent" tooltip="{i18n>btnBackToCostChart}" press=".onResetCostChart" visible="{detail>/isBomChart}"/>
                                                        <Button icon="sap-icon://full-screen" type="Transparent" tooltip="{i18n>btnFullScreen}"/>
                                                    </OverflowToolbar>
                                                </headerToolbar>
                                                <content>
                                                    <viz:VizFrame id="costDonutChart"
                                                        vizType="donut"
                                                        width="100%"
                                                        height="22rem"
                                                        selectData=".onCostChartSelect">
                                                    </viz:VizFrame>
                                                </content>
                                            </Panel>

                                            <Panel class="breakdownPanel bomCostPanel" backgroundDesign="Solid" visible="{detail>/isFinishedProduct}">
                                                <headerToolbar>
                                                    <OverflowToolbar>
                                                        <Title text="{i18n>bomCostTitle}" level="H2"/>
                                                        <ToolbarSpacer/>
                                                        <Button icon="sap-icon://full-screen" type="Transparent" tooltip="{i18n>btnFullScreen}"/>
                                                    </OverflowToolbar>
                                                </headerToolbar>
                                                <content>
                                                    <Table id="bomCostTable"
                                                        items="{detail>/to_BOMCostBreakdown/results}"
                                                        mode="None"
                                                        noDataText="{i18n>bomCostNoData}">
                                                        <columns>
                                                            <Column width="46%">
                                                                <Label text="{i18n>colBomComponent}"/>
                                                            </Column>
                                                            <Column hAlign="End" width="8rem">
                                                                <Label text="{i18n>colBomQuantity}"/>
                                                            </Column>
                                                            <Column hAlign="End" width="7rem">
                                                                <Label text="{i18n>colBomUnitCost}"/>
                                                            </Column>
                                                            <Column hAlign="End" width="7.5rem">
                                                                <Label text="{i18n>colBomAmount}"/>
                                                            </Column>
                                                            <Column hAlign="Center" width="4.5rem">
                                                                <Label text="{i18n>colCurrency}"/>
                                                            </Column>
                                                        </columns>
                                                        <items>
                                                            <ColumnListItem>
                                                                <Text text="{parts: [{path: 'detail>maktx'}, {path: 'detail>idnrk'}], formatter: '.formatBomComponentName'}"/>
                                                                <ObjectNumber number="{parts: [{path: 'detail>menge'}, {path: 'detail>bmeng'}], formatter: '.formatBomComponentQuantity'}" unit="{detail>meins}" emphasized="false"/>
                                                                <ObjectNumber class="amountText" number="{parts: [{path: 'detail>comp_unit_cost'}, {path: 'detail>waers'}], formatter: '.formatAmount'}" emphasized="false"/>
                                                                <ObjectNumber class="amountText" number="{parts: [{path: 'detail>comp_total_cost'}, {path: 'detail>waers'}], formatter: '.formatAmount'}" emphasized="true"/>
                                                                <Text text="{detail>waers}"/>
                                                            </ColumnListItem>
                                                        </items>
                                                    </Table>
                                                </content>
                                            </Panel>
                                        </VBox>

                                        <Panel class="costHistoryPanel" backgroundDesign="Solid">
                                            <headerToolbar>
                                                <OverflowToolbar>
                                                    <Title text="{i18n>costHistoryTitle}" level="H2"/>
                                                    <ToolbarSpacer/>
                                                    <Button icon="sap-icon://full-screen" type="Transparent" tooltip="{i18n>btnFullScreen}"/>
                                                </OverflowToolbar>
                                            </headerToolbar>
                                            <content>
                                                <VBox class="costHistoryChartBox" width="100%">
                                                    <viz:VizFrame id="costHistoryLineChart"
                                                        uiConfig="{applicationSet:'fiori'}"
                                                        vizType="line"
                                                        width="100%"
                                                        height="30rem"
                                                        selectData=".onCostHistorySelect">
                                                    </viz:VizFrame>
                                                </VBox>
                                            </content>
                                        </Panel>
                                    </content>
                                </IconTabFilter>

                                <IconTabFilter key="variance" text="{i18n>tabActualVariance}" icon="sap-icon://compare" tooltip="{i18n>tabActualVarianceTooltip}">
                                    <content>
                                        <VBox class="varianceTabContent" busy="{detail>/variance/busy}">
                                            <Panel class="varianceSummaryPanel" backgroundDesign="Solid">
                                                <headerToolbar>
                                                    <OverflowToolbar>
                                                        <Title text="{i18n>varianceSummaryTitle}" level="H2"/>
                                                        <ToolbarSpacer/>
                                                        <ObjectStatus
                                                            text="{detail>/variance/data/actualStatusText}"
                                                            state="{detail>/variance/data/actualStatusState}"/>
                                                    </OverflowToolbar>
                                                </headerToolbar>
                                                <content>
                                                    <Table
                                                        items="{detail>/variance/metricRows}"
                                                        mode="None"
                                                        noDataText="{i18n>varianceNoData}">
                                                        <columns>
                                                            <Column width="42%">
                                                                <Label text="{i18n>varianceMetric}"/>
                                                            </Column>
                                                            <Column hAlign="End">
                                                                <Label text="{i18n>varianceAmount}"/>
                                                            </Column>
                                                            <Column hAlign="Center" width="6rem">
                                                                <Label text="{i18n>colCurrency}"/>
                                                            </Column>
                                                        </columns>
                                                        <items>
                                                            <ColumnListItem>
                                                                <Text text="{detail>label}"/>
                                                                <ObjectStatus
                                                                    text="{path: 'detail>value', formatter: '.formatAmount'}"
                                                                    state="{detail>state}"/>
                                                                <Text text="{detail>unit}" textAlign="Center"/>
                                                            </ColumnListItem>
                                                        </items>
                                                    </Table>
                                                </content>
                                            </Panel>
                                        </VBox>
                                    </content>
                                </IconTabFilter>

                                <IconTabFilter key="reservation" text="{i18n>tabReservationTracking}" icon="sap-icon://table-view" tooltip="{i18n>tabReservationTrackingTooltip}">
                                    <content>
                                        <Panel class="reservationSummaryCard reservationSummaryInline" backgroundDesign="Solid">
                                            <content>
                                                <HBox alignItems="Center" justifyContent="SpaceAround" class="reservationSummary">
                                                    <Title text="{i18n>reservationSummaryTitle}" level="H3"/>
                                                    <ObjectStatus icon="sap-icon://documents" title="{i18n>summaryReservationCount}" text="{path: 'detail>/reservationSummary/count', formatter: '.formatQuantity'}"/>
                                                    <ObjectStatus icon="sap-icon://shipping-status" title="{i18n>summaryOpenQuantity}" text="{path: 'detail>/reservationSummary/openQuantity', formatter: '.formatQuantity'}" state="Information"/>
                                                </HBox>
                                            </content>
                                        </Panel>
                                        <Table id="reservationTable"
                                            items="{detail>/reservationRows}"
                                            mode="None"
                                            updateFinished=".onReservationUpdateFinished"
                                            class="reservationTable">
                                            <columns>
                                                <Column>
                                                    <Label text="{i18n>colReservationSource}"/>
                                                </Column>
                                                <Column>
                                                    <Label text="{i18n>colReservationDoc}"/>
                                                </Column>
                                                <Column>
                                                    <Label text="{i18n>colReservationItem}"/>
                                                </Column>
                                                <Column hAlign="End">
                                                    <Label text="{i18n>colResme}"/>
                                                </Column>
                                                <Column hAlign="Center">
                                                    <Label text="{i18n>colUnit}"/>
                                                </Column>
                                                <Column hAlign="Center">
                                                    <Label text="{i18n>colReservationStatus}"/>
                                                </Column>
                                            </columns>
                                            <items>
                                                <ColumnListItem>
                                                    <Text text="{detail>source}"/>
                                                    <Text text="{detail>document}"/>
                                                    <Text text="{detail>item}"/>
                                                    <ObjectNumber number="{path: 'detail>reservationQuantity', formatter: '.formatQuantity'}" emphasized="false"/>
                                                    <Text text="{detail>meins}"/>
                                                    <ObjectStatus text="{detail>statusText}" state="{detail>statusState}"/>
                                                </ColumnListItem>
                                            </items>
                                        </Table>
                                    </content>
                                </IconTabFilter>
                            </items>
                        </IconTabBar>
                    </content>
                </Panel>
            </VBox>
        </content>
    </Page>
</mvc:View>
