<mvc:View controllerName="ze4.co.s.cost.ze4coscost.controller.StandardCost"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:u="sap.ui.unified"
    xmlns:t="sap.ui.table">
    <Page id="page" title="{i18n>title}" showNavButton="false" showHeader="false">
        <content>
            <VBox class="sapUiContentPadding standardCostPage" width="100%">
                <Title text="{i18n>title}" level="H1" titleStyle="H1" class="pageHeroTitle"/>

                <Panel class="filterPanel appCard" width="100%" backgroundDesign="Solid">
                    <content>
                        <FlexBox wrap="Wrap" alignItems="End" class="filterGrid">
                            <VBox class="filterField">
                                <Label text="{i18n>lblYear}" labelFor="inputYear"/>
                                <Input id="inputYear" value="{view>/filters/gjahr}" type="Text" width="13rem" maxLength="4" submit=".onSearch"/>
                            </VBox>

                            <VBox class="filterField">
                                <Label text="{i18n>lblMonth}" labelFor="inputMonth"/>
                                <Input id="inputMonth" value="{view>/filters/monat}" type="Text" width="13rem" maxLength="2" submit=".onSearch"/>
                            </VBox>

                            <VBox class="filterField">
                                <Label text="{i18n>lblMaterial}" labelFor="inputMatnr"/>
                                <Input id="inputMatnr" value="{view>/filters/matnr}" placeholder="{i18n>plhMaterial}" width="13rem" showValueHelp="true" valueHelpIconSrc="sap-icon://search" submit=".onSearch"/>
                            </VBox>

                            <VBox class="filterField">
                                <Label text="{i18n>lblMaterialType}" labelFor="inputMtart"/>
                                <Input id="inputMtart" value="{view>/filters/mtart}" placeholder="{i18n>plhSelect}" width="13rem" showValueHelp="true" valueHelpIconSrc="sap-icon://search" valueHelpRequest=".onMtartValueHelp" submit=".onSearch"/>
                            </VBox>

                            <VBox class="filterField">
                                <Label text="{i18n>lblMaterialGroup}" labelFor="inputMatkl"/>
                                <Input id="inputMatkl" value="{view>/filters/matkl}" placeholder="{i18n>plhSelect}" width="13rem" showValueHelp="true" valueHelpIconSrc="sap-icon://search" valueHelpRequest=".onMatklValueHelp" submit=".onSearch"/>
                            </VBox>

                            <HBox class="filterActions">
                                <Button text="{i18n>btnSearch}" icon="sap-icon://search" type="Emphasized" press=".onSearch"/>
                                <Button text="{i18n>btnReset}" icon="sap-icon://reset" press=".onResetFilters"/>
                            </HBox>
                        </FlexBox>
                    </content>
                </Panel>

                <Panel class="appCard summaryPanel" width="100%" backgroundDesign="Solid">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="{= ${view>/filters/gjahr} + '년 ' + ${view>/filters/monat} + '월 원가/재고 요약' }" level="H2"/>
                            <ToolbarSpacer/>
                            <Button text="{i18n>btnExcelExport}" icon="sap-icon://excel-attachment" press=".onExportToExcel"/>
                            <Button text="{i18n>btnPdfExport}" icon="sap-icon://print" press=".onExportToPdf"/>
                            <Button icon="sap-icon://action-settings" type="Transparent" tooltip="{i18n>btnSettings}"/>
                            <Button icon="sap-icon://full-screen" type="Transparent" tooltip="{i18n>btnFullScreen}"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <t:Table id="costSummaryTable"
                            rows="{view>/costData}"
                            selectionMode="Single"
                            rowSelectionChange=".onRowSelectionChange"
                            enableColumnReordering="true"
                            enableGrouping="true"
                            alternateRowColors="true"
                            visibleRowCountMode="Fixed"
                            visibleRowCount="8"
                            rowHeight="40"
                            columnHeaderHeight="34"
                            class="costSummaryTable"
                            noData="{i18n>msgNoData}">
                            <t:columns>
                                <t:Column width="5.6rem" hAlign="Center">
                                    <Label text="{i18n>colAction}" class="singleHeaderLabel"/>
                                    <t:template>
                                        <Button text="{i18n>btnDetail}" icon="sap-icon://detail-view" type="Transparent" width="5rem" tooltip="{i18n>btnDetailTooltip}" visible="{= !!${view>matnr} }" press=".onOpenDetail"/>
                                    </t:template>
                                </t:Column>
                                <t:Column width="8rem">
                                    <Label text="{i18n>colMatnr}" class="singleHeaderLabel"/>
                                    <t:template>
                                        <Text text="{view>matnr}"/>
                                    </t:template>
                                </t:Column>
                                <t:Column width="18.5rem">
                                    <Label text="{i18n>colMaktx}" class="singleHeaderLabel"/>
                                    <t:template>
                                        <Text text="{view>maktx}"/>
                                    </t:template>
                                </t:Column>
                                <t:Column width="14.5rem">
                                    <Label text="{i18n>colOptionText}" class="singleHeaderLabel"/>
                                    <t:template>
                                        <Text text="{view>mtopt_t}"/>
                                    </t:template>
                                </t:Column>
                                <t:Column width="8.8rem">
                                    <Label text="{i18n>colMaterialType}" class="singleHeaderLabel"/>
                                    <t:template>
                                        <Text text="{view>mtbez}"/>
                                    </t:template>
                                </t:Column>
                                <t:Column width="8.8rem">
                                    <Label text="{i18n>colMaterialGroup}" class="singleHeaderLabel"/>
                                    <t:template>
                                        <Text text="{view>wgbez}"/>
                                    </t:template>
                                </t:Column>
                                <t:Column width="8.6rem" hAlign="End">
                                    <Label text="{i18n>colTotalCost}" class="singleHeaderLabel"/>
                                    <t:template>
                                        <ObjectNumber class="amountText" number="{parts: [{path: 'view>total_cost'}, {path: 'view>waers'}], formatter: '.formatAmount'}" emphasized="false"/>
                                    </t:template>
                                </t:Column>
                                <t:Column width="4.2rem">
                                    <Label text="{i18n>colCurrency}" class="singleHeaderLabel"/>
                                    <t:template>
                                        <Text text="{view>waers}"/>
                                    </t:template>
                                </t:Column>
                                <t:Column width="7.6rem" hAlign="End" headerSpan="4">
                                    <t:multiLabels>
                                        <Label text="{i18n>stockFlowGroup}" width="100%" textAlign="Center" wrapping="true" class="stockGroupHeader"/>
                                        <Label text="{i18n>colAvailStock}" width="100%" textAlign="End" class="stockSubHeader"/>
                                    </t:multiLabels>
                                    <t:template>
                                        <HBox justifyContent="End" alignItems="Center" width="100%">
                                            <ObjectNumber number="{path: 'view>total_clabs', formatter: '.formatQuantity'}" emphasized="false" visible="{path: 'view>mtopt', formatter: '.isDefaultOption'}"/>
                                            <Text text="{i18n>customOrderStockMessage}" wrapping="false" visible="{path: 'view>mtopt', formatter: '.isCustomOption'}"/>
                                        </HBox>
                                    </t:template>
                                </t:Column>
                                <t:Column width="4.9rem" hAlign="End">
                                    <t:multiLabels>
                                        <Label text=""/>
                                        <Label text="{i18n>colInspection}" width="100%" textAlign="End" class="stockSubHeader"/>
                                    </t:multiLabels>
                                    <t:template>
                                        <ObjectNumber number="{path: 'view>total_verme', formatter: '.formatQuantity'}" emphasized="false" visible="{path: 'view>mtopt', formatter: '.isDefaultOption'}"/>
                                    </t:template>
                                </t:Column>
                                <t:Column width="4.9rem" hAlign="End">
                                    <t:multiLabels>
                                        <Label text=""/>
                                        <Label text="{i18n>colHoldStock}" width="100%" textAlign="End" class="stockSubHeader"/>
                                    </t:multiLabels>
                                    <t:template>
                                        <ObjectNumber number="{path: 'view>total_cspem', formatter: '.formatQuantity'}" emphasized="false" visible="{path: 'view>mtopt', formatter: '.isDefaultOption'}"/>
                                    </t:template>
                                </t:Column>
                                <t:Column width="4.9rem" hAlign="End">
                                    <t:multiLabels>
                                        <Label text=""/>
                                        <Label text="{i18n>colReservation}" width="100%" textAlign="End" class="stockSubHeader"/>
                                    </t:multiLabels>
                                    <t:template>
                                        <ObjectNumber number="{path: 'view>total_resme', formatter: '.formatQuantity'}" emphasized="false" visible="{path: 'view>mtopt', formatter: '.isDefaultOption'}"/>
                                    </t:template>
                                </t:Column>
                                <t:Column width="4rem" hAlign="Center">
                                    <Label text="{i18n>colUnit}" class="singleHeaderLabel"/>
                                    <t:template>
                                        <Text text="{view>meins}" visible="{path: 'view>mtopt', formatter: '.isDefaultOption'}"/>
                                    </t:template>
                                </t:Column>
                            </t:columns>
                        </t:Table>
                        <OverflowToolbar class="tableFooter">
                            <ObjectStatus icon="sap-icon://information" text="{i18n>rowSelectHint}" state="Information"/>
                            <ToolbarSpacer/>
                            <Text text="{path: 'view>/costData', formatter: '.formatResultCount'}"/>
                        </OverflowToolbar>
                    </content>
                </Panel>
            </VBox>
        </content>
    </Page>
</mvc:View>
