<mvc:View
    controllerName="ze4.co.pa.ze4copa.controller.ProfitabilityAnalysis"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizData="sap.viz.ui5.data"
    xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds">
    <f:DynamicPage id="actualPlanPage" class="coPage coActualPlanPage" fitContent="true">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <VBox>
                        <Title text="[EverNiture-CO] 실적 / 계획 수익성 비교" level="H1" class="coPageTitle"/>
                        <Text text="CO/FI 전표 및 예산 기준 Actual vs Plan 분석" class="coPageSubtitle"/>
                    </VBox>
                </f:heading>
                <f:actions>
                    <Button text="종합 현황" icon="sap-icon://home" type="Transparent" press=".onGoCockpit"/>
                    <Button text="제품/옵션 분석" icon="sap-icon://product" type="Transparent" press=".onGoProduct"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <VBox class="coHeaderContent">
                    <HBox class="coFilterBar" wrap="Wrap" alignItems="End">
                        <VBox class="coFilterItem">
                            <Label text="회사코드" required="true"/>
                            <Input value="{app>/filters/companyCode}" editable="false"/>
                        </VBox>
                        <VBox class="coFilterItem">
                            <Label text="회계연도" required="true"/>
                            <Select selectedKey="{app>/filters/fiscalYear}" width="100%" items="{app>/yearOptions}">
                                <core:Item key="{app>key}" text="{app>text}"/>
                            </Select>
                        </VBox>
                        <VBox class="coFilterItem">
                            <Label text="회계기간" required="true"/>
                            <Select selectedKey="{app>/filters/month}" width="100%" items="{app>/monthOptions}">
                                <core:Item key="{app>key}" text="{app>text}"/>
                            </Select>
                        </VBox>
                        <VBox class="coFilterItem coFilterItemSmall">
                            <Label text="계획 버전" required="true"/>
                            <Input value="{app>/filters/planVersion}" maxLength="3" editable="false"/>
                        </VBox>
                        <VBox class="coFilterItem">
                            <Label text="사업부문"/>
                            <ComboBox selectedKey="{app>/filters/segment}" width="100%" items="{app>/actualPlanValueHelp/segments}">
                                <core:Item key="{app>key}" text="{app>text}"/>
                            </ComboBox>
                        </VBox>
                        <VBox class="coFilterItem">
                            <Label text="손익센터"/>
                            <ComboBox selectedKey="{app>/filters/prctr}" width="100%" items="{app>/actualPlanValueHelp/profitCenters}">
                                <core:Item key="{app>key}" text="{app>text}"/>
                            </ComboBox>
                        </VBox>
                        <VBox class="coFilterItem">
                            <Label text="기능영역(FKBER)"/>
                            <ComboBox selectedKey="{app>/filters/fkber}" width="100%" items="{app>/actualPlanValueHelp/functionalAreas}">
                                <core:Item key="{app>key}" text="{app>text}"/>
                            </ComboBox>
                        </VBox>
                        <HBox class="coFilterActions" alignItems="End">
                            <Button text="조회" type="Emphasized" press=".onSearch"/>
                            <Button text="필터 초기화" type="Transparent" press=".onResetFilters"/>
                        </HBox>
                    </HBox>
                </VBox>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <VBox class="coContent coActualPlanContent" fitContainer="true" busy="{app>/actualPlanBusy}">
                <MessageStrip
                    text="{app>/actualPlanMessage}"
                    type="Information"
                    showIcon="true"
                    visible="{= !!${app>/actualPlanMessage} }"
                    class="coMessageStrip"/>

                <HBox class="coKpiGrid" wrap="Wrap">
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://bar-chart" class="coKpiIcon coKpiIconBlue"/>
                            <VBox>
                                <Text text="매출 실적" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/actualPlanKpi/salesActual', formatter:'.formatter.amount'}" unit="{app>/actualPlanKpi/currency}" emphasized="true" state="Information"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://target-group" class="coKpiIcon coKpiIconPurple"/>
                            <VBox>
                                <Text text="매출 계획" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/actualPlanKpi/salesPlan', formatter:'.formatter.amount'}" unit="{app>/actualPlanKpi/currency}" emphasized="true" state="Information"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://compare" class="coKpiIcon coKpiIconOrange"/>
                            <VBox>
                                <Text text="매출 차이" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/actualPlanKpi/salesDiff', formatter:'.formatter.amount'}" unit="{app>/actualPlanKpi/currency}" emphasized="true" state="{path:'app>/actualPlanKpi/salesDiff', formatter:'.formatter.stateByAmount'}"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://trend-up" class="coKpiIcon coKpiIconTeal"/>
                            <VBox>
                                <Text text="영업이익 실적" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/actualPlanKpi/operatingProfitActual', formatter:'.formatter.amount'}" unit="{app>/actualPlanKpi/currency}" emphasized="true" state="{path:'app>/actualPlanKpi/operatingProfitActual', formatter:'.formatter.stateByAmount'}"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://target-group" class="coKpiIcon coKpiIconGreen"/>
                            <VBox>
                                <Text text="영업이익 계획" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/actualPlanKpi/operatingProfitPlan', formatter:'.formatter.amount'}" unit="{app>/actualPlanKpi/currency}" emphasized="true" state="{path:'app>/actualPlanKpi/operatingProfitPlan', formatter:'.formatter.stateByAmount'}"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://compare" class="coKpiIcon coKpiIconOrange"/>
                            <VBox>
                                <Text text="영업이익 차이" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/actualPlanKpi/operatingProfitDiff', formatter:'.formatter.amount'}" unit="{app>/actualPlanKpi/currency}" emphasized="true" state="{path:'app>/actualPlanKpi/operatingProfitDiff', formatter:'.formatter.stateByAmount'}"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://pie-chart" class="coKpiIcon coKpiIconBlue"/>
                            <VBox>
                                <Text text="영업이익률 차이" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/actualPlanKpi/operatingProfitRateDiff', formatter:'.formatter.percent'}" emphasized="true" state="{path:'app>/actualPlanKpi/operatingProfitRateDiff', formatter:'.formatter.stateByRate'}"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <HBox class="coMainGrid coActualPlanCharts" wrap="Wrap">
                    <VBox class="coPanel coPanelHalf">
                        <Title text="1. 월별 Actual vs Plan" level="H3" class="coPanelTitle"/>
                        <viz:VizFrame
                            id="actualPlanMonthlyChart"
                            class="coActualPlanChart"
                            width="100%"
                            height="21rem"
                            vizType="column"
                            uiConfig="{applicationSet:'fiori'}">
                            <viz:dataset>
                                <vizData:FlattenedDataset data="{app>/actualPlanMonthlyChart}">
                                    <vizData:dimensions>
                                        <vizData:DimensionDefinition name="월" value="{app>monthText}"/>
                                    </vizData:dimensions>
                                    <vizData:measures>
                                        <vizData:MeasureDefinition name="실적" value="{app>actual}"/>
                                        <vizData:MeasureDefinition name="계획" value="{app>plan}"/>
                                    </vizData:measures>
                                </vizData:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="실적,계획"/>
                                <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="월"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>

                    <VBox class="coPanel coPanelHalf">
                        <Title text="2. 프로핏센터별 영업이익 Top/Bottom" level="H3" class="coPanelTitle"/>
                        <viz:VizFrame
                            id="actualPlanProfitCenterChart"
                            class="coActualPlanChart"
                            width="100%"
                            height="21rem"
                            vizType="column"
                            uiConfig="{applicationSet:'fiori'}">
                            <viz:dataset>
                                <vizData:FlattenedDataset data="{app>/actualPlanProfitCenterChart}">
                                    <vizData:dimensions>
                                        <vizData:DimensionDefinition name="손익센터" value="{app>profitCenter}"/>
                                    </vizData:dimensions>
                                    <vizData:measures>
                                        <vizData:MeasureDefinition name="영업이익 실적" value="{app>actualOperatingProfit}"/>
                                    </vizData:measures>
                                </vizData:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="영업이익 실적"/>
                                <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="손익센터"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>

                    <VBox class="coPanel coPanelHalf">
                        <Title text="3. 손익 항목별 실적-계획 차이" level="H3" class="coPanelTitle"/>
                        <viz:VizFrame
                            id="actualPlanVarianceChart"
                            class="coActualPlanChart"
                            width="100%"
                            height="21rem"
                            vizType="column"
                            uiConfig="{applicationSet:'fiori'}">
                            <viz:dataset>
                                <vizData:FlattenedDataset data="{app>/actualPlanVarianceChart}">
                                    <vizData:dimensions>
                                        <vizData:DimensionDefinition name="손익 항목" value="{app>item}"/>
                                    </vizData:dimensions>
                                    <vizData:measures>
                                        <vizData:MeasureDefinition name="실적 - 계획" value="{app>diff}"/>
                                    </vizData:measures>
                                </vizData:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="실적 - 계획"/>
                                <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="손익 항목"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>
                </HBox>

                <VBox class="coPanel coActualPlanDetailPanel">
                    <Toolbar class="coPanelToolbar">
                        <Title text="4. 프로핏센터 수익성 상세" level="H3"/>
                        <ToolbarSpacer/>
                        <Button icon="sap-icon://product" text="제품/옵션 분석" type="Transparent" press=".onGoProduct"/>
                    </Toolbar>
                    <ScrollContainer horizontal="true" vertical="true" width="100%" height="100%" class="coActualPlanDetailScroller">
                        <Table
                            width="273rem"
                            items="{app>/actualPlanRows}"
                            noDataText="조회 결과가 없습니다."
                            sticky="ColumnHeaders"
                            class="coTable">
                            <columns>
                                <Column width="6rem"><Text text="회계기간"/></Column>
                                <Column width="16rem"><Text text="사업부문"/></Column>
                                <Column width="16rem"><Text text="손익센터"/></Column>
                                <Column width="16rem"><Text text="기능영역"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="매출 실적"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="매출 계획"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="매출 차이"/></Column>
                                <Column width="8rem" hAlign="End"><Text text="매출 달성률"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="매출원가 실적"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="매출원가 계획"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="매출총이익 실적"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="매출총이익 계획"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="매출총이익 차이"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="판관비 실적"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="판관비 계획"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="판관비 차이"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="영업이익 실적"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="영업이익 계획"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="영업이익 차이"/></Column>
                                <Column width="9rem" hAlign="End"><Text text="영업이익 달성률"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="제조/차이 실적"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="제조/차이 계획"/></Column>
                                <Column width="11rem" hAlign="End"><Text text="제조/차이 차이"/></Column>
                                <Column width="6rem"><Text text="통화"/></Column>
                                <Column width="5rem" hAlign="Center"><Text text="전표"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{app>monat}"/>
                                        <ObjectIdentifier title="{app>segmentDisplay}"/>
                                        <ObjectIdentifier title="{app>prctrDisplay}"/>
                                        <ObjectIdentifier title="{app>fkberDisplay}"/>
                                        <ObjectNumber number="{path:'app>actualSales', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>planSales', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>salesDiff', formatter:'.formatter.amount'}" unit="{app>waers}" state="{app>salesDiffState}"/>
                                        <ObjectStatus text="{path:'app>salesAchievementRate', formatter:'.formatter.percent'}" state="{path:'app>salesAchievementRate', formatter:'.formatter.stateByRate'}" inverted="true" class="coRateChip"/>
                                        <ObjectNumber number="{path:'app>actualCogs', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>planCogs', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>actualGrossProfit', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>planGrossProfit', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>grossProfitDiff', formatter:'.formatter.amount'}" unit="{app>waers}" state="{app>grossProfitDiffState}"/>
                                        <ObjectNumber number="{path:'app>actualSga', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>planSga', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>sgaDiff', formatter:'.formatter.amount'}" unit="{app>waers}" state="{app>sgaDiffState}"/>
                                        <ObjectNumber number="{path:'app>actualOperatingProfit', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>planOperatingProfit', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>operatingProfitDiff', formatter:'.formatter.amount'}" unit="{app>waers}" state="{app>operatingProfitDiffState}"/>
                                        <ObjectStatus text="{path:'app>opProfitAchievementRate', formatter:'.formatter.percent'}" state="{path:'app>opProfitAchievementRate', formatter:'.formatter.stateByRate'}" inverted="true" class="coRateChip"/>
                                        <ObjectNumber number="{path:'app>actualVariance', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>planVariance', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>varianceDiff', formatter:'.formatter.amount'}" unit="{app>waers}" state="{app>varianceDiffState}"/>
                                        <Text text="{app>waers}"/>
                                        <Button icon="sap-icon://detail-view" type="Transparent" tooltip="전표 상세" press=".onOpenProfitCenterDrilldown"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </ScrollContainer>
                </VBox>
            </VBox>
        </f:content>
    </f:DynamicPage>

    <Dialog id="profitCenterDrilldownDialog" title="전표 상세 - {app>/selectedDrilldownTitle}" contentWidth="88rem" contentHeight="38rem" resizable="true" draggable="true">
        <VBox class="coDialogContent" busy="{app>/drilldownBusy}">
            <MessageStrip
                text="{app>/drilldownMessage}"
                type="Information"
                showIcon="true"
                visible="{= !!${app>/drilldownMessage} }"
                class="coMessageStrip"/>
            <ScrollContainer horizontal="true" vertical="true" width="100%" height="32rem">
                <Table
                    width="144rem"
                    items="{app>/drilldownRows}"
                    noDataText="조회 결과가 없습니다."
                    growing="true"
                    growingThreshold="30"
                    class="coTable">
                    <columns>
                        <Column width="6rem"><Text text="전표유형"/></Column>
                        <Column width="9rem"><Text text="전표번호"/></Column>
                        <Column width="6rem"><Text text="라인"/></Column>
                        <Column width="6rem"><Text text="연도"/></Column>
                        <Column width="6rem"><Text text="기간"/></Column>
                        <Column width="8rem"><Text text="전기일"/></Column>
                        <Column width="8rem"><Text text="계정"/></Column>
                        <Column width="13rem"><Text text="계정명"/></Column>
                        <Column width="12rem"><Text text="계정 성격"/></Column>
                        <Column width="12rem"><Text text="계정그룹"/></Column>
                        <Column width="6rem"><Text text="차대"/></Column>
                        <Column width="10rem" hAlign="End"><Text text="전표금액"/></Column>
                        <Column width="10rem" hAlign="End"><Text text="손익금액"/></Column>
                        <Column width="6rem"><Text text="통화"/></Column>
                        <Column width="8rem" hAlign="End"><Text text="수량"/></Column>
                        <Column width="6rem"><Text text="단위"/></Column>
                        <Column width="16rem"><Text text="손익센터"/></Column>
                        <Column width="16rem"><Text text="사업부문"/></Column>
                        <Column width="16rem"><Text text="기능영역"/></Column>
                        <Column width="24rem"><Text text="제품"/></Column>
                        <Column width="10rem"><Text text="옵션"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{app>blart}"/>
                                <Text text="{app>belnr}"/>
                                <Text text="{app>docln}"/>
                                <Text text="{app>gjahr}"/>
                                <Text text="{app>monat}"/>
                                <Text text="{app>budat}"/>
                                <Text text="{app>racct}"/>
                                <Text text="{app>racct_txt}"/>
                                <ObjectStatus text="{app>accountRoleText}" tooltip="{app>accountRoleDetail}" state="Information"/>
                                <Text text="{app>acct_group_txt}"/>
                                <Text text="{app>drcrk}"/>
                                <ObjectNumber number="{path:'app>raw_amount', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                <ObjectNumber number="{path:'app>pl_amount', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                <Text text="{app>waers}"/>
                                <Text text="{path:'app>quantity', formatter:'.formatter.decimal'}"/>
                                <Text text="{app>meins}"/>
                                <ObjectIdentifier title="{app>prctrDisplay}"/>
                                <ObjectIdentifier title="{app>segmentDisplay}"/>
                                <ObjectIdentifier title="{app>fkberDisplay}"/>
                                <ObjectIdentifier title="{app>productDisplay}" text="{app>materialGroupDisplay}" class="coProductCell"/>
                                <Text text="{app>optionDisplay}" wrapping="false"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </ScrollContainer>
        </VBox>
        <endButton>
            <Button text="닫기" press=".onCloseDrilldown"/>
        </endButton>
    </Dialog>

</mvc:View>
