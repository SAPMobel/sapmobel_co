<mvc:View
    controllerName="ze4.co.pa.ze4copa.controller.ProfitabilityAnalysis"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizData="sap.viz.ui5.data"
    xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds">
    <f:DynamicPage id="cockpitPage" class="coPage" fitContent="false" showFooter="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <VBox>
                        <Title text="[EverNiture-CO] 수익성 분석 종합 현황" level="H1" class="coPageTitle"/>
                        <Text text="CO/FI 구조 기반 수익성 분석" class="coPageSubtitle"/>
                    </VBox>
                </f:heading>
                <f:actions>
                    <Button text="제품/옵션 상세보기" icon="sap-icon://product" type="Transparent" press=".onGoProduct"/>
                    <Button text="실적/계획 비교" icon="sap-icon://compare" type="Transparent" press=".onGoActualPlan"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <VBox class="coHeaderContent">
                    <HBox class="coFilterBar" wrap="Wrap" alignItems="End">
                        <VBox class="coFilterItem">
                            <Label text="회사코드" required="true"/>
                            <Input value="{app>/filters/companyCode}" editable="false"/>
                        </VBox>
                        <VBox class="coFilterItem">
                            <Label text="회계연도" required="true"/>
                            <Select selectedKey="{app>/filters/fiscalYear}" width="100%" items="{app>/yearOptions}">
                                <core:Item key="{app>key}" text="{app>text}"/>
                            </Select>
                        </VBox>
                        <VBox class="coFilterItem">
                            <Label text="회계기간" required="true"/>
                            <Select selectedKey="{app>/filters/month}" width="100%" items="{app>/monthOptions}">
                                <core:Item key="{app>key}" text="{app>text}"/>
                            </Select>
                        </VBox>
                        <HBox class="coFilterActions" alignItems="End">
                            <Button text="조회" type="Emphasized" press=".onSearch"/>
                            <Button text="필터 초기화" type="Transparent" press=".onResetFilters"/>
                        </HBox>
                    </HBox>
                </VBox>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <VBox class="coContent" busy="{app>/busy}">
                <MessageStrip
                    text="{app>/productMessage}"
                    type="Information"
                    showIcon="true"
                    visible="{= !!${app>/productMessage} }"
                    class="coMessageStrip"/>

                <HBox class="coKpiGrid" wrap="Wrap">
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://bar-chart" class="coKpiIcon coKpiIconBlue"/>
                            <VBox>
                                <Text text="매출" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/kpi/sales', formatter:'.formatter.amount'}" unit="{app>/kpi/currency}" emphasized="true" state="Information"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://cart" class="coKpiIcon coKpiIconPurple"/>
                            <VBox>
                                <Text text="매출원가" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/kpi/cogs', formatter:'.formatter.amount'}" unit="{app>/kpi/currency}" emphasized="true" state="Warning"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://lead" class="coKpiIcon coKpiIconGreen"/>
                            <VBox>
                                <Text text="매출총이익" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/kpi/grossProfit', formatter:'.formatter.amount'}" unit="{app>/kpi/currency}" emphasized="true" state="{path:'app>/kpi/grossProfit', formatter:'.formatter.stateByAmount'}"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://org-chart" class="coKpiIcon coKpiIconOrange"/>
                            <VBox>
                                <Text text="배부 대상 판관비" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/kpi/sgaPool', formatter:'.formatter.amount'}" unit="{app>/kpi/currency}" emphasized="true" state="Warning"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://trend-up" class="coKpiIcon coKpiIconTeal"/>
                            <VBox>
                                <Text text="영업이익" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/kpi/operatingProfit', formatter:'.formatter.amount'}" unit="{app>/kpi/currency}" emphasized="true" state="{path:'app>/kpi/operatingProfit', formatter:'.formatter.stateByAmount'}"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://pie-chart" class="coKpiIcon coKpiIconBlue"/>
                            <VBox>
                                <Text text="영업이익률" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/kpi/operatingProfitRate', formatter:'.formatter.percent'}" emphasized="true" state="{path:'app>/kpi/operatingProfitRate', formatter:'.formatter.stateByRate'}"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <HBox class="coMainGrid coCockpitMainGrid" wrap="Wrap">
                    <VBox class="coPanel coPanelWide">
                        <Title text="1. 월별 손익 추이" level="H3" class="coPanelTitle"/>
                        <viz:VizFrame
                            id="cockpitMonthlyChart"
                            width="100%"
                            height="20rem"
                            vizType="combination"
                            uiConfig="{applicationSet:'fiori'}">
                            <viz:dataset>
                                <vizData:FlattenedDataset data="{app>/monthlyChart}">
                                    <vizData:dimensions>
                                        <vizData:DimensionDefinition name="월" value="{app>monthText}"/>
                                    </vizData:dimensions>
                                    <vizData:measures>
                                        <vizData:MeasureDefinition name="매출" value="{app>sales}"/>
                                        <vizData:MeasureDefinition name="매출원가" value="{app>cogs}"/>
                                        <vizData:MeasureDefinition name="매출총이익" value="{app>grossProfit}"/>
                                        <vizData:MeasureDefinition name="판관비" value="{app>sga}"/>
                                        <vizData:MeasureDefinition name="영업이익" value="{app>operatingProfit}"/>
                                    </vizData:measures>
                                </vizData:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="매출,매출원가,매출총이익,판관비,영업이익"/>
                                <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="월"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>

                    <VBox class="coPanel coPanelNarrow">
                        <Title text="2. 사업부문 비중" level="H3" class="coPanelTitle"/>
                        <MessageStrip
                            text="{app>/segmentShareMessage}"
                            type="Information"
                            showIcon="true"
                            visible="{= !!${app>/segmentShareMessage} }"
                            class="coMessageStrip"/>
                        <viz:VizFrame
                            id="cockpitShareChart"
                            width="100%"
                            height="15rem"
                            vizType="donut"
                            uiConfig="{applicationSet:'fiori'}">
                            <viz:dataset>
                                <vizData:FlattenedDataset data="{app>/segmentShareChart}">
                                    <vizData:dimensions>
                                        <vizData:DimensionDefinition name="사업부문" value="{app>segmentDisplay}"/>
                                    </vizData:dimensions>
                                    <vizData:measures>
                                        <vizData:MeasureDefinition name="매출" value="{app>amount}"/>
                                    </vizData:measures>
                                </vizData:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <vizFeeds:FeedItem uid="size" type="Measure" values="매출"/>
                                <vizFeeds:FeedItem uid="color" type="Dimension" values="사업부문"/>
                            </viz:feeds>
                        </viz:VizFrame>
                        <Table
                            items="{app>/segmentShareChart}"
                            noDataText="사업부문 기준 매출 데이터가 없습니다."
                            class="coMiniTable">
                            <columns>
                                <Column><Text text="사업부문"/></Column>
                                <Column hAlign="End"><Text text="매출"/></Column>
                                <Column hAlign="End"><Text text="비중"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <ObjectIdentifier title="{app>segmentDisplay}"/>
                                        <ObjectNumber number="{path:'app>amount', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                        <ObjectNumber number="{path:'app>share', formatter:'.formatter.percent'}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>

                    <VBox class="coPanel coPanelMedium">
                        <Title text="3. 손익 구조" level="H3" class="coPanelTitle"/>
                        <viz:VizFrame
                            id="cockpitStructureChart"
                            width="100%"
                            height="20rem"
                            vizType="column"
                            uiConfig="{applicationSet:'fiori'}">
                            <viz:dataset>
                                <vizData:FlattenedDataset data="{app>/monthlyChart}">
                                    <vizData:dimensions>
                                        <vizData:DimensionDefinition name="구분" value="{app>structureText}"/>
                                    </vizData:dimensions>
                                    <vizData:measures>
                                        <vizData:MeasureDefinition name="매출" value="{app>sales}"/>
                                        <vizData:MeasureDefinition name="매출원가" value="{app>cogs}"/>
                                        <vizData:MeasureDefinition name="매출총이익" value="{app>grossProfit}"/>
                                        <vizData:MeasureDefinition name="판관비" value="{app>sga}"/>
                                        <vizData:MeasureDefinition name="영업이익" value="{app>operatingProfit}"/>
                                    </vizData:measures>
                                </vizData:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="매출,매출원가,매출총이익,판관비,영업이익"/>
                                <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="구분"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>

                    <VBox class="coPanel coPanelInfo coCriteriaPanel">
                        <Title text="분석 기준" level="H3" class="coPanelTitle coCriteriaTitle"/>
                        <VBox class="coCriteriaList">
                            <HBox class="coCriteriaItem coCriteriaRevenue" alignItems="Center">
                                <core:Icon src="sap-icon://sales-order" class="coCriteriaIcon"/>
                                <VBox class="coCriteriaText">
                                    <Text text="매출" class="coCriteriaName"/>
                                    <Text text="4xxxx" class="coCriteriaBadge"/>
                                </VBox>
                            </HBox>
                            <HBox class="coCriteriaItem coCriteriaCogs" alignItems="Center">
                                <core:Icon src="sap-icon://cart" class="coCriteriaIcon"/>
                                <VBox class="coCriteriaText">
                                    <Text text="매출원가" class="coCriteriaName"/>
                                    <Text text="6xxxx" class="coCriteriaBadge"/>
                                </VBox>
                            </HBox>
                            <HBox class="coCriteriaItem coCriteriaSga" alignItems="Center">
                                <core:Icon src="sap-icon://account" class="coCriteriaIcon"/>
                                <VBox class="coCriteriaText">
                                    <Text text="판관비" class="coCriteriaName"/>
                                    <Text text="7xxxx" class="coCriteriaBadge"/>
                                </VBox>
                            </HBox>
                            <HBox class="coCriteriaItem coCriteriaVariance" alignItems="Center">
                                <core:Icon src="sap-icon://factory" class="coCriteriaIcon"/>
                                <VBox class="coCriteriaText">
                                    <Text text="제조/차이" class="coCriteriaName"/>
                                    <Text text="8xxxx" class="coCriteriaBadge"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                </HBox>

                <VBox class="coPanel">
                    <Toolbar class="coPanelToolbar">
                        <Title text="4. 제품/옵션 수익성 Top" level="H3"/>
                    </Toolbar>
                    <Table
                        width="100%"
                        fixedLayout="true"
                        items="{app>/topRows}"
                        noDataText="조회 결과가 없습니다."
                        growing="true"
                        growingThreshold="10"
                        class="coTable">
                        <columns>
                            <Column width="12%"><Text text="제품"/></Column>
                            <Column width="6%"><Text text="옵션"/></Column>
                            <Column width="22%" hAlign="End"><Text text="매출"/></Column>
                            <Column width="22%" hAlign="End"><Text text="매출총이익"/></Column>
                            <Column width="22%" hAlign="End"><Text text="영업이익"/></Column>
                            <Column width="10%" hAlign="End"><Text text="영업이익률"/></Column>
                            <Column width="6%" hAlign="Center"><Text text="상태"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <ObjectIdentifier title="{app>productDisplay}" text="{app>materialGroupDisplay}" class="coProductCell"/>
                                    <Text text="{app>optionDisplay}" wrapping="false"/>
                                    <ObjectNumber number="{path:'app>sales', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                    <ObjectNumber number="{path:'app>grossProfit', formatter:'.formatter.amount'}" unit="{app>waers}" state="{app>profitState}"/>
                                    <ObjectNumber number="{path:'app>operatingProfit', formatter:'.formatter.amount'}" unit="{app>waers}" state="{app>profitState}"/>
                                    <ObjectStatus text="{path:'app>operatingProfitRate', formatter:'.formatter.percent'}" state="{path:'app>operatingProfitRate', formatter:'.formatter.stateByRate'}" inverted="true" class="coRateChip"/>
                                    <ObjectStatus text="{= ${app>operatingProfit} > 0 ? '흑자' : (${app>operatingProfit} &lt; 0 ? '적자' : '-') }" state="{app>profitState}" class="coStatusCell"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>
            </VBox>
        </f:content>
    </f:DynamicPage>

</mvc:View>
