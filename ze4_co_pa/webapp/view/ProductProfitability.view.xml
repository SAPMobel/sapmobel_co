<mvc:View
    controllerName="ze4.co.pa.ze4copa.controller.ProfitabilityAnalysis"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizData="sap.viz.ui5.data"
    xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds">
    <f:DynamicPage id="productPage" class="coPage" fitContent="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <VBox>
                        <Title text="[EverNiture-CO] 제품 / 옵션 판매 수익성 분석" level="H1" class="coPageTitle"/>
                        <Text text="제품/옵션 판매 기준 수익성" class="coPageSubtitle"/>
                    </VBox>
                </f:heading>
                <f:actions>
                    <Button text="종합 현황" icon="sap-icon://home" type="Transparent" press=".onGoCockpit"/>
                    <Button text="실적/계획 비교" icon="sap-icon://compare" type="Transparent" press=".onGoActualPlan"/>
                    <Button text="Excel 다운로드" icon="sap-icon://excel-attachment" type="Transparent" press=".onExportExcel"/>
                    <Button text="PDF 다운로드" icon="sap-icon://print" type="Transparent" press=".onExportPdf"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <VBox class="coHeaderContent">
                    <HBox class="coFilterBar" wrap="Wrap" alignItems="End">
                        <VBox class="coFilterItem">
                            <Label text="회사코드" required="true"/>
                            <Input value="{app>/filters/companyCode}" editable="false"/>
                        </VBox>
                        <VBox class="coFilterItem">
                            <Label text="회계연도" required="true"/>
                            <Select selectedKey="{app>/filters/fiscalYear}" width="100%" items="{app>/yearOptions}">
                                <core:Item key="{app>key}" text="{app>text}"/>
                            </Select>
                        </VBox>
                        <VBox class="coFilterItem">
                            <Label text="회계기간" required="true"/>
                            <Select selectedKey="{app>/filters/month}" width="100%" items="{app>/monthOptions}">
                                <core:Item key="{app>key}" text="{app>text}"/>
                            </Select>
                        </VBox>
                        <VBox class="coFilterItem">
                            <Label text="제품"/>
                            <Input value="{app>/filters/matnr}" maxLength="40" submit=".onSearch"/>
                        </VBox>
                        <VBox class="coFilterItem">
                            <Label text="옵션"/>
                            <Input value="{app>/filters/mtopt}" maxLength="8" submit=".onSearch"/>
                        </VBox>
                        <VBox class="coFilterItem coFilterItemSmall">
                            <Label text="자재유형"/>
                            <Input value="{app>/filters/mtart}" maxLength="4" submit=".onSearch"/>
                        </VBox>
                        <VBox class="coFilterItem">
                            <Label text="자재그룹"/>
                            <Input value="{app>/filters/matkl}" maxLength="9" submit=".onSearch"/>
                        </VBox>
                        <HBox class="coFilterActions" alignItems="End">
                            <Button text="조회" type="Emphasized" press=".onSearch"/>
                            <Button text="필터 초기화" type="Transparent" press=".onResetFilters"/>
                        </HBox>
                    </HBox>
                </VBox>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <VBox class="coContent" busy="{app>/productBusy}">
                <MessageStrip
                    text="{app>/productMessage}"
                    type="Information"
                    showIcon="true"
                    visible="{= !!${app>/productMessage} }"
                    class="coMessageStrip"/>
                <MessageStrip
                    text="이 화면은 제품/옵션별 판매 수익성 기준입니다. 렌탈수익 및 렌탈 직접비는 제외되며, 공통관리비는 판매매출과 렌탈수익의 비중에 따라 판매분만 반영됩니다."
                    type="Information"
                    showIcon="true"
                    class="coMessageStrip"/>
                <HBox class="coKpiGrid" wrap="Wrap">
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://bar-chart" class="coKpiIcon coKpiIconBlue"/>
                            <VBox>
                                <Text text="판매매출" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/kpi/sales', formatter:'.formatter.amount'}" unit="{app>/kpi/currency}" emphasized="true" state="Information"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://cart" class="coKpiIcon coKpiIconPurple"/>
                            <VBox>
                                <Text text="판매매출원가" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/kpi/cogs', formatter:'.formatter.amount'}" unit="{app>/kpi/currency}" emphasized="true" state="Warning"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://lead" class="coKpiIcon coKpiIconGreen"/>
                            <VBox>
                                <Text text="판매총이익" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/kpi/grossProfit', formatter:'.formatter.amount'}" unit="{app>/kpi/currency}" emphasized="true" state="{path:'app>/kpi/grossProfit', formatter:'.formatter.stateByAmount'}"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://org-chart" class="coKpiIcon coKpiIconOrange"/>
                            <VBox>
                                <Text text="판매기준 판관비 합계" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/kpi/sgaPool', formatter:'.formatter.amount'}" unit="{app>/kpi/currency}" emphasized="true" state="Warning"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://trend-up" class="coKpiIcon coKpiIconTeal"/>
                            <VBox>
                                <Text text="판매기준 영업이익" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/kpi/operatingProfit', formatter:'.formatter.amount'}" unit="{app>/kpi/currency}" emphasized="true" state="{path:'app>/kpi/operatingProfit', formatter:'.formatter.stateByAmount'}"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox class="coKpiCard">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://pie-chart" class="coKpiIcon coKpiIconBlue"/>
                            <VBox>
                                <Text text="판매기준 영업이익률" class="coKpiLabel"/>
                                <ObjectNumber number="{path:'app>/kpi/operatingProfitRate', formatter:'.formatter.percent'}" emphasized="true" state="{path:'app>/kpi/operatingProfitRate', formatter:'.formatter.stateByRate'}"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <HBox class="coMainGrid" wrap="Wrap">
                    <VBox class="coPanel coPanelHalf coReferenceChartPanel">
                        <Title text="제품/옵션별 판매기준 영업이익 TOP 10" level="H3" class="coPanelTitle"/>
                        <viz:VizFrame
                            id="productProfitChart"
                            width="100%"
                            height="27rem"
                            vizType="bar"
                            uiConfig="{applicationSet:'fiori'}">
                            <viz:dataset>
                                <vizData:FlattenedDataset data="{app>/topRows}">
                                    <vizData:dimensions>
                                        <vizData:DimensionDefinition name="제품/옵션" value="{app>productKey}"/>
                                    </vizData:dimensions>
                                    <vizData:measures>
                                        <vizData:MeasureDefinition name="판매기준 영업이익" value="{app>operatingProfit}"/>
                                    </vizData:measures>
                                </vizData:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="판매기준 영업이익"/>
                                <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="제품/옵션"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>

                    <VBox class="coPanel coPanelHalf">
                        <Title text="제품그룹별 판매총이익률 / 판매기준 영업이익률" level="H3" class="coPanelTitle"/>
                        <viz:VizFrame
                            id="productMarginChart"
                            width="100%"
                            height="27rem"
                            vizType="column"
                            selectData=".onProductMarginChartSelect"
                            deselectData=".onProductMarginChartDeselect"
                            uiConfig="{applicationSet:'fiori'}">
                            <viz:dataset>
                                <vizData:FlattenedDataset data="{app>/marginChart}">
                                    <vizData:dimensions>
                                        <vizData:DimensionDefinition name="제품그룹" value="{app>productKey}"/>
                                    </vizData:dimensions>
                                    <vizData:measures>
                                        <vizData:MeasureDefinition name="판매총이익률" value="{app>grossProfitRate}"/>
                                        <vizData:MeasureDefinition name="판매기준 영업이익률" value="{app>operatingProfitRate}"/>
                                    </vizData:measures>
                                </vizData:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="판매총이익률,판매기준 영업이익률"/>
                                <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="제품그룹"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>
                </HBox>

                <VBox class="coPanel">
                    <Toolbar class="coPanelToolbar">
                        <Title text="제품/옵션 판매 수익성 상세" level="H3"/>
                        <ToolbarSpacer/>
                        <Button icon="sap-icon://home" text="종합 현황" type="Transparent" press=".onGoCockpit"/>
                    </Toolbar>
                    <ScrollContainer horizontal="false" vertical="true" width="100%" height="34rem" class="coProductDetailScroller">
                        <Table
                            width="100%"
                            fixedLayout="true"
                            items="{app>/productRows}"
                            noDataText="조회 결과가 없습니다."
                            sticky="ColumnHeaders"
                            class="coTable coProductDetailTable">
                            <columns>
                                <Column width="17rem"><Text text="제품"/></Column>
                                <Column width="7.5rem"><Text text="옵션"/></Column>
                                <Column width="4.6rem"><Text text="제품유형"/></Column>
                                <Column width="5rem"><Text text="제품그룹"/></Column>
                                <Column width="5.8rem" hAlign="End"><Text text="판매매출" class="coColumnRed"/></Column>
                                <Column width="6.2rem" hAlign="End"><Text text="판매매출원가" class="coColumnPurple"/></Column>
                                <Column width="5.8rem" hAlign="End"><Text text="판매총이익" class="coColumnRed"/></Column>
                                <Column width="5rem" hAlign="End"><Text text="판매총이익률" class="coColumnOrange"/></Column>
                                <Column width="6.5rem" hAlign="End"><Text text="제품별 배부 판관비" class="coColumnPurple"/></Column>
                                <Column width="6.5rem" hAlign="End"><Text text="판매기준 영업이익" class="coColumnRed"/></Column>
                                <Column width="8rem" hAlign="End"><Text text="판매기준 영업이익률" class="coColumnOrange"/></Column>
                                <Column width="3.2rem" hAlign="Center"><Text text="상태"/></Column>
                                <Column width="6.2rem" hAlign="Center"><Text text="전표"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <ObjectIdentifier title="{app>productDisplay}" text="{app>materialGroupDisplay}" class="coProductCell"/>
                                        <Text text="{app>optionDisplay}" wrapping="false"/>
                                        <Text text="{app>materialTypeDisplay}"/>
                                        <Text text="{app>materialGroupDisplay}"/>
                                        <ObjectNumber number="{path:'app>sales', formatter:'.formatter.amount'}" unit="{app>waers}" class="coAmountRed"/>
                                        <ObjectNumber number="{path:'app>cogs', formatter:'.formatter.amount'}" unit="{app>waers}" class="coAmountPurple"/>
                                        <ObjectNumber number="{path:'app>grossProfit', formatter:'.formatter.amount'}" unit="{app>waers}" state="{app>profitState}" class="coAmountRed"/>
                                        <ObjectStatus text="{path:'app>grossProfitRate', formatter:'.formatter.percent'}" state="{path:'app>grossProfitRate', formatter:'.formatter.stateByRate'}" class="coRateChip coAmountOrange"/>
                                        <ObjectNumber number="{path:'app>allocatedSga', formatter:'.formatter.amount'}" unit="{app>waers}" class="coAmountPurple"/>
                                        <ObjectNumber number="{path:'app>operatingProfit', formatter:'.formatter.amount'}" unit="{app>waers}" state="{app>profitState}" class="coAmountRed"/>
                                        <ObjectStatus text="{path:'app>operatingProfitRate', formatter:'.formatter.percent'}" state="{path:'app>operatingProfitRate', formatter:'.formatter.stateByRate'}" class="coRateChip coAmountOrange"/>
                                        <ObjectStatus text="{= ${app>operatingProfit} >= 0 ? '흑자' : '적자' }" state="{app>profitState}" class="coStatusCell"/>
                                        <HBox justifyContent="Center" alignItems="Center" renderType="Bare" class="coJournalActionGroup">
                                            <Button icon="sap-icon://sales-order" type="Transparent" tooltip="판매매출 전표 상세" press=".onOpenProductDrilldown">
                                                <customData>
                                                    <core:CustomData key="detailType" value="SALES"/>
                                                </customData>
                                            </Button>
                                            <Button icon="sap-icon://cart" type="Transparent" tooltip="판매매출원가 전표 상세" press=".onOpenProductDrilldown">
                                                <customData>
                                                    <core:CustomData key="detailType" value="COGS"/>
                                                </customData>
                                            </Button>
                                            <Button icon="sap-icon://detail-view" type="Transparent" tooltip="제품/옵션 전체 전표 상세" press=".onOpenProductDrilldown">
                                                <customData>
                                                    <core:CustomData key="detailType" value="ALL"/>
                                                </customData>
                                            </Button>
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </ScrollContainer>
                </VBox>
            </VBox>
        </f:content>
    </f:DynamicPage>

    <Dialog id="drilldownDialog" title="전표 상세 - {app>/selectedProductTitle}" contentWidth="88rem" contentHeight="38rem" resizable="true" draggable="true">
        <VBox class="coDialogContent" busy="{app>/drilldownBusy}">
            <MessageStrip
                text="판매 수익성 기준 합계에는 렌탈수익 및 렌탈 직접비가 제외됩니다."
                type="Information"
                showIcon="true"
                class="coMessageStrip"/>
            <MessageStrip
                text="{app>/drilldownMessage}"
                type="Information"
                showIcon="true"
                visible="{= !!${app>/drilldownMessage} }"
                class="coMessageStrip"/>
            <ScrollContainer horizontal="true" vertical="true" width="100%" height="32rem">
                <Table
                    width="172rem"
                    items="{app>/drilldownRows}"
                    noDataText="조회 결과가 없습니다."
                    growing="true"
                    growingThreshold="30"
                    class="coTable">
                    <columns>
                        <Column width="6rem"><Text text="전표유형"/></Column>
                        <Column width="9rem"><Text text="전표번호"/></Column>
                        <Column width="6rem"><Text text="라인"/></Column>
                        <Column width="6rem"><Text text="연도"/></Column>
                        <Column width="6rem"><Text text="기간"/></Column>
                        <Column width="8rem"><Text text="전기일"/></Column>
                        <Column width="8rem"><Text text="계정"/></Column>
                        <Column width="13rem"><Text text="계정명"/></Column>
                        <Column width="12rem"><Text text="계정 성격"/></Column>
                        <Column width="12rem"><Text text="프로세스 단계"/></Column>
                        <Column width="8rem"><Text text="최종 반영"/></Column>
                        <Column width="12rem"><Text text="계정그룹"/></Column>
                        <Column width="6rem"><Text text="차대"/></Column>
                        <Column width="10rem" hAlign="End"><Text text="전표금액"/></Column>
                        <Column width="10rem" hAlign="End"><Text text="손익금액"/></Column>
                        <Column width="6rem"><Text text="통화"/></Column>
                        <Column width="8rem" hAlign="End"><Text text="수량"/></Column>
                        <Column width="6rem"><Text text="단위"/></Column>
                        <Column width="9rem"><Text text="송신 코스트센터"/></Column>
                        <Column width="9rem"><Text text="수신 코스트센터"/></Column>
                        <Column width="16rem"><Text text="손익센터"/></Column>
                        <Column width="16rem"><Text text="사업부문"/></Column>
                        <Column width="24rem"><Text text="제품"/></Column>
                        <Column width="10rem"><Text text="옵션"/></Column>
                        <Column width="12rem"><Text text="제품유형"/></Column>
                        <Column width="12rem"><Text text="제품그룹"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{app>blart}"/>
                                <Text text="{app>belnr}"/>
                                <Text text="{app>docln}"/>
                                <Text text="{app>gjahr}"/>
                                <Text text="{app>monat}"/>
                                <Text text="{app>budat}"/>
                                <Text text="{app>racct}"/>
                                <Text text="{app>racct_txt}"/>
                                <ObjectStatus text="{app>accountRoleText}" tooltip="{app>accountRoleDetail}" state="Information"/>
                                <ObjectStatus text="{app>processStepText}" tooltip="{app>processStepDetail}" state="Information"/>
                                <Text text="{app>finalManufacturingText}" wrapping="false"/>
                                <Text text="{app>acct_group_txt}"/>
                                <Text text="{app>drcrk}"/>
                                <ObjectNumber number="{path:'app>raw_amount', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                <ObjectNumber number="{path:'app>pl_amount', formatter:'.formatter.amount'}" unit="{app>waers}"/>
                                <Text text="{app>waers}"/>
                                <Text text="{path:'app>quantity', formatter:'.formatter.decimal'}"/>
                                <Text text="{app>meins}"/>
                                <Text text="{app>s_kostl}" wrapping="false"/>
                                <Text text="{app>r_kostl}" wrapping="false"/>
                                <ObjectIdentifier title="{app>prctrDisplay}"/>
                                <ObjectIdentifier title="{app>segmentDisplay}"/>
                                <ObjectIdentifier title="{app>productDisplay}" text="{app>materialGroupDisplay}" class="coProductCell"/>
                                <Text text="{app>optionDisplay}" wrapping="false"/>
                                <Text text="{app>materialTypeDisplay}"/>
                                <Text text="{app>materialGroupDisplay}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </ScrollContainer>
        </VBox>
        <endButton>
            <Button text="닫기" press=".onCloseDrilldown"/>
        </endButton>
    </Dialog>

</mvc:View>
